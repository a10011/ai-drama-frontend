<template>
  <div class="progress-page">
    <div class="progress-header">
      <h2 class="gradient-text">{{ drama.title || '视频生成中' }}</h2>
      <div class="status-badge" :class="drama.status">
        <i class="fas" :class="statusIcon"></i>
        {{ statusText }}
      </div>
    </div>

    <!-- 总体进度 -->
    <div class="glass-card rounded-3xl p-8 mb-6">
      <div class="flex items-center justify-between mb-3">
        <span class="text-sm font-medium text-gray-400">总体进度</span>
        <span class="text-2xl font-bold gradient-text">{{ drama.progress }}%</span>
      </div>
      <div class="w-full bg-gray-800 rounded-full h-4 overflow-hidden">
        <div 
          class="h-full bg-gradient-to-r from-violet-500 via-fuchsia-500 to-cyan-500 rounded-full transition-all duration-1000"
          :style="{ width: drama.progress + '%' }"
        ></div>
      </div>
      <p class="text-center text-gray-500 mt-4 text-sm">{{ currentMessage }}</p>
    </div>

    <!-- 智能体流水线步骤 -->
    <div class="space-y-3 mb-6">
      <div 
        v-for="(step, index) in pipelineSteps" 
        :key="index"
        class="glass-card rounded-xl p-4 border-l-4 transition-all duration-500"
        :class="{
          'border-green-500': step.status === 'completed',
          'border-violet-500': step.status === 'active',
          'border-gray-700 opacity-60': step.status === 'pending'
        }"
      >
        <div class="flex items-start gap-4">
          <div 
            class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 transition-all"
            :class="{
              'bg-green-500/20': step.status === 'completed',
              'bg-violet-500/20 animate-pulse': step.status === 'active',
              'bg-gray-700/50': step.status === 'pending'
            }"
          >
            <i class="fas" :class="step.icon" :class="{
              'text-green-400': step.status === 'completed',
              'text-violet-400': step.status === 'active',
              'text-gray-500': step.status === 'pending'
            }"></i>
          </div>
          <div class="flex-1">
            <div class="flex items-center justify-between mb-1">
              <div class="flex items-center gap-2">
                <h3 class="font-semibold text-white" :class="{ 'text-gray-500': step.status === 'pending' }">
                  {{ step.name }}
                </h3>
                <span class="fancy-tag text-xs" :class="step.tagClass">
                  <i class="fas fa-robot mr-1"></i>{{ step.agent }}
                </span>
              </div>
              <span class="text-xs" :class="step.statusClass">{{ step.statusText }}</span>
            </div>
            <p class="text-sm text-gray-400">{{ step.description }}</p>

            <!-- 子步骤进度 -->
            <div v-if="step.subSteps && step.status === 'active'" class="mt-3 space-y-2">
              <div 
                v-for="(sub, sIdx) in step.subSteps" 
                :key="sIdx"
                class="flex items-center gap-2 text-xs"
              >
                <i class="fas" :class="sub.completed ? 'fa-check-circle text-green-400' : 'fa-circle text-gray-600'"></i>
                <span :class="sub.completed ? 'text-gray-300' : 'text-gray-500'">{{ sub.name }}</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 视频预览 -->
    <div v-if="drama.status === 'completed' && drama.videoUrl" class="glass-card rounded-3xl p-6 mb-6">
      <h3 class="text-lg font-semibold text-white mb-4 flex items-center gap-2">
        <i class="fas fa-play-circle text-green-400"></i>生成完成
      </h3>
      <video 
        :src="drama.videoUrl" 
        controls 
        class="w-full rounded-2xl max-h-[500px] bg-black"
      ></video>
      <div class="flex justify-center gap-4 mt-6">
        <a 
          :href="drama.videoUrl" 
          download 
          class="btn-primary px-6 py-3 rounded-xl text-white font-medium flex items-center gap-2"
        >
          <i class="fas fa-download"></i>下载视频
        </a>
        <button 
          @click="copyLink" 
          class="glass px-6 py-3 rounded-xl text-white font-medium flex items-center gap-2 hover:bg-white/10"
        >
          <i class="fas fa-link"></i>复制链接
        </button>
      </div>
    </div>

    <!-- 错误提示 -->
    <div v-if="drama.status === 'failed'" class="glass-card rounded-3xl p-6 mb-6 border border-red-500/30">
      <div class="flex items-center gap-3 mb-4">
        <div class="w-12 h-12 rounded-xl bg-red-500/20 flex items-center justify-center">
          <i class="fas fa-exclamation-triangle text-red-400 text-xl"></i>
        </div>
        <div>
          <h3 class="text-lg font-bold text-white">生成失败</h3>
          <p class="text-sm text-red-400">{{ drama.errorMsg || '未知错误' }}</p>
        </div>
      </div>
      <div class="flex gap-3">
        <button 
          @click="retryGenerate" 
          :loading="retrying"
          class="btn-primary px-6 py-3 rounded-xl text-white font-medium flex items-center gap-2"
        >
          <i class="fas fa-redo"></i>重新生成
        </button>
        <button 
          @click="saveAsDraft" 
          class="glass px-6 py-3 rounded-xl text-white font-medium flex items-center gap-2 hover:bg-white/10"
        >
          <i class="fas fa-save"></i>存为草稿
        </button>
      </div>
    </div>

    <!-- 实时日志 -->
    <div class="glass-card rounded-3xl overflow-hidden">
      <button @click="showLogs = !showLogs" class="w-full p-4 flex items-center justify-between hover:bg-white/5 transition">
        <div class="flex items-center gap-2">
          <i class="fas fa-terminal text-gray-500"></i>
          <span class="font-medium text-white">生成日志</span>
          <span class="px-2 py-0.5 rounded-full bg-gray-700 text-gray-400 text-xs">实时</span>
        </div>
        <i class="fas fa-chevron-down text-gray-500 transition-transform" :class="{ 'rotate-180': showLogs }"></i>
      </button>
      <div v-show="showLogs" class="border-t border-white/10">
        <div class="log-container p-4 max-h-80 overflow-y-auto">
          <div 
            v-for="(log, index) in logs" 
            :key="index"
            class="log-line"
          >
            <span class="log-time">{{ log.time }}</span>
            <span class="log-level" :class="log.level">{{ log.level.toUpperCase() }}</span>
            <span class="text-gray-300">{{ log.message }}</span>
          </div>
          <div v-if="logs.length === 0" class="text-gray-500 text-center py-8">
            等待日志输出...
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup>
import { ref, reactive, computed, onMounted, onUnmounted } from 'vue'
import { useRoute, useRouter } from 'vue-router'
import { ElMessage } from 'element-plus'
import { getDramaDetail, retryDrama } from '@/api/drama'

const route = useRoute()
const router = useRouter()
const dramaId = route.params.id

const drama = reactive({
  title: '',
  status: 'processing',
  progress: 0,
  videoUrl: null,
  errorMsg: null
})

const logs = ref([])
const showLogs = ref(false)
const retrying = ref(false)
let pollTimer = null
let ws = null

// 智能体流水线步骤
const pipelineSteps = computed(() => [
  {
    name: '剧本解析',
    agent: '编剧智能体',
    icon: 'fa-book',
    status: drama.progress >= 10 ? 'completed' : 'pending',
    description: 'AI分析剧本内容，提取场景和角色',
    tagClass: 'bg-blue-500/20 text-blue-300 border-blue-500/30',
    statusClass: 'text-green-400',
    statusText: drama.progress >= 10 ? '已完成' : '等待中'
  },
  {
    name: '分镜生成',
    agent: '分镜师智能体',
    icon: 'fa-film',
    status: drama.progress >= 15 ? 'completed' : drama.progress >= 10 ? 'active' : 'pending',
    description: '根据剧本生成分镜脚本和画面描述',
    tagClass: 'bg-pink-500/20 text-pink-300 border-pink-500/30',
    statusClass: drama.progress >= 15 ? 'text-green-400' : 'text-violet-400',
    statusText: drama.progress >= 15 ? '已完成' : drama.progress >= 10 ? '进行中' : '等待中'
  },
  {
    name: '角色建模',
    agent: '建模智能体',
    icon: 'fa-cube',
    status: drama.progress >= 20 ? 'completed' : drama.progress >= 15 ? 'active' : 'pending',
    description: '3D角色建模、骨骼绑定、表情系统',
    tagClass: 'bg-green-500/20 text-green-300 border-green-500/30',
    statusClass: drama.progress >= 20 ? 'text-green-400' : 'text-violet-400',
    statusText: drama.progress >= 20 ? '已完成' : drama.progress >= 15 ? '进行中' : '等待中',
    subSteps: drama.progress >= 15 ? [
      { name: '面部特征提取', completed: drama.progress >= 16 },
      { name: '3D模型生成', completed: drama.progress >= 17 },
      { name: '骨骼绑定', completed: drama.progress >= 18 },
      { name: '表情系统', completed: drama.progress >= 19 }
    ] : null
  },
  {
    name: '画面生成',
    agent: '视觉智能体',
    icon: 'fa-image',
    status: drama.progress >= 25 && drama.progress < 95 ? 'active' : drama.progress >= 95 ? 'completed' : 'pending',
    description: '调用AI模型生成视频画面',
    tagClass: 'bg-violet-500/20 text-violet-300 border-violet-500/30',
    statusClass: drama.progress >= 95 ? 'text-green-400' : 'text-violet-400',
    statusText: drama.progress >= 95 ? '已完成' : drama.progress >= 25 ? '进行中' : '等待中'
  },
  {
    name: '视频合成',
    agent: '剪辑智能体',
    icon: 'fa-magic',
    status: drama.progress >= 95 ? 'active' : 'pending',
    description: '合成画面、配音、音乐、字幕',
    tagClass: 'bg-amber-500/20 text-amber-300 border-amber-500/30',
    statusClass: 'text-violet-400',
    statusText: drama.progress >= 95 ? '进行中' : '等待中'
  },
  {
    name: '后期特效',
    agent: '特效智能体',
    icon: 'fa-sparkles',
    status: drama.status === 'completed' ? 'completed' : 'pending',
    description: '添加视觉特效、片头片尾',
    tagClass: 'bg-cyan-500/20 text-cyan-300 border-cyan-500/30',
    statusClass: drama.status === 'completed' ? 'text-green-400' : 'text-gray-500',
    statusText: drama.status === 'completed' ? '已完成' : '等待中'
  }
])

const statusIcon = computed(() => ({
  processing: 'fa-spinner fa-spin',
  completed: 'fa-check-circle',
  failed: 'fa-exclamation-circle'
})[drama.status] || 'fa-question-circle')

const statusText = computed(() => ({
  processing: '生成中',
  completed: '已完成',
  failed: '失败',
  pending: '等待中'
})[drama.status] || '未知')

const currentMessage = computed(() => {
  if (drama.status === 'completed') return '视频生成完成！'
  if (drama.status === 'failed') return drama.errorMsg || '生成失败'
  return 'AI正在努力创作中，请耐心等待...'
})

const fetchProgress = async () => {
  try {
    const res = await getDramaDetail(dramaId)
    if (res.data) {
      Object.assign(drama, res.data)

      if (res.data.status === 'completed' || res.data.status === 'failed') {
        clearInterval(pollTimer)
      }
    }
  } catch (error) {
    console.error('获取进度失败:', error)
  }
}

const connectWebSocket = () => {
  const token = localStorage.getItem('token')
  if (!token) return

  const wsUrl = `wss://api.mzsh.top/ws?token=${token}`
  ws = new WebSocket(wsUrl)

  ws.onmessage = (event) => {
    const data = JSON.parse(event.data)
    if (data.dramaId === dramaId) {
      if (data.type === 'drama_progress') {
        drama.progress = data.progress
        drama.status = data.status
        logs.value.push({
          time: new Date().toLocaleTimeString(),
          level: data.level || 'info',
          message: data.message
        })
        // 保持日志数量限制
        if (logs.value.length > 100) {
          logs.value = logs.value.slice(-100)
        }
      }
      if (data.type === 'drama_completed') {
        drama.status = 'completed'
        drama.progress = 100
        drama.videoUrl = data.videoUrl
        clearInterval(pollTimer)
        ElMessage.success('视频生成完成！')
      }
      if (data.type === 'drama_failed') {
        drama.status = 'failed'
        drama.errorMsg = data.error
        clearInterval(pollTimer)
      }
    }
  }

  ws.onerror = (error) => {
    console.error('WebSocket错误:', error)
  }
}

const retryGenerate = async () => {
  retrying.value = true
  try {
    await retryDrama(dramaId)
    drama.status = 'processing'
    drama.progress = 5
    drama.errorMsg = null
    logs.value = []
    startPolling()
    ElMessage.success('重新开始生成')
  } catch (error) {
    ElMessage.error(error.message || '重试失败')
  } finally {
    retrying.value = false
  }
}

const saveAsDraft = () => {
  ElMessage.success('已保存为草稿')
  router.push('/projects')
}

const copyLink = () => {
  if (drama.videoUrl) {
    navigator.clipboard.writeText(drama.videoUrl)
    ElMessage.success('链接已复制')
  }
}

const startPolling = () => {
  fetchProgress()
  pollTimer = setInterval(fetchProgress, 3000)
}

onMounted(() => {
  fetchProgress()
  startPolling()
  connectWebSocket()
})

onUnmounted(() => {
  clearInterval(pollTimer)
  if (ws) ws.close()
})
</script>

<style scoped>
.progress-page {
  max-width: 900px;
  margin: 0 auto;
  padding: 20px;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30px;
}

.progress-header h2 {
  font-size: 2rem;
  font-weight: 700;
}

.status-badge {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  border-radius: 100px;
  font-size: 14px;
  font-weight: 500;
}

.status-badge.processing {
  background: rgba(139, 92, 246, 0.2);
  color: #a78bfa;
}

.status-badge.completed {
  background: rgba(16, 185, 129, 0.2);
  color: #34d399;
}

.status-badge.failed {
  background: rgba(239, 68, 68, 0.2);
  color: #f87171;
}

.glass-card {
  background: rgba(30, 30, 58, 0.6);
  backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.gradient-text {
  background: linear-gradient(135deg, #8b5cf6, #ec4899, #06b6d4);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.fancy-tag {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  border-radius: 100px;
  font-size: 12px;
  font-weight: 500;
  border: 1px solid;
}

.btn-primary {
  background: linear-gradient(135deg, #7c3aed, #db2777);
  box-shadow: 0 4px 20px rgba(124, 58, 237, 0.4);
  transition: all 0.3s ease;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(124, 58, 237, 0.6);
}

.log-container {
  background: rgba(0, 0, 0, 0.6);
  font-family: 'Courier New', monospace;
  font-size: 13px;
}

.log-line {
  margin: 5px 0;
  line-height: 1.6;
}

.log-time {
  color: #858585;
  margin-right: 10px;
}

.log-level {
  padding: 2px 6px;
  border-radius: 3px;
  margin-right: 10px;
  font-size: 11px;
  font-weight: bold;
}

.log-level.info { background: #0e639c; color: #fff; }
.log-level.success { background: #16825d; color: #fff; }
.log-level.error { background: #c72c0c; color: #fff; }
.log-level.warning { background: #d97706; color: #fff; }

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.animate-pulse {
  animation: pulse 2s infinite;
}
</style>