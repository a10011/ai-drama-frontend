}
.panel-title {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.panel-toggle {
  border: none;
  background: transparent;
  color: var(--text-muted);
  font-size: 12px;
