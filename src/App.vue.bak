<template>
  <div class="editor-layout" :class="{ 'is-login-page': isLoginPage }">
    <!-- ===== 顶部菜单栏 Top Menu Bar ===== -->
    <header class="topbar">
      <div class="topbar-left">
        <div class="logo-area">
          <span class="logo-icon">◆</span>
          <span class="logo-text">智剧工作台</span>
          <span class="logo-version">v4.0</span>
        </div>
        <div class="top-divider"></div>
        <!-- 顶部 Tab 切换 -->
        <nav class="top-tabs">
          <button
            v-for="tab in topTabs"
            :key="tab.key"
            class="tab-btn"
            :class="{ active: activeModule === tab.key }"
            @click="switchModule(tab.key)"
          >
            <span class="tab-icon">{{ tab.icon }}</span>
            <span class="tab-label">{{ tab.label }}</span>
          </button>
        </nav>
      </div>

      <div class="topbar-right">
        <!-- 算力/次数 -->
        <div class="credit-badge">
          <span class="credit-dot"></span>
          <span class="credit-label">{{ tierLabel }}</span>
          <span class="credit-sep">|</span>
          <span class="credit-value">{{ creditDisplay }}</span>
        </div>

        <!-- 用户区 -->
        <div v-if="isLoggedIn" class="user-area" @click="showUserMenu = !showUserMenu" ref="userRef">
          <span class="user-avatar">{{ userInitial }}</span>
          <span class="user-name">{{ shortName }}</span>
          <span class="user-arrow">▾</span>
          <!-- 下拉菜单 -->
          <div v-if="showUserMenu" class="user-menu">
            <div class="menu-item" @click="goProfile">账号设置</div>
            <div class="menu-item" @click="goHistory">创作历史</div>
            <div class="menu-divider"></div>
            <div class="menu-item danger" @click="logout">退出登录</div>
          </div>
        </div>
        <template v-else>
          <button class="btn btn-ghost btn-sm" @click="$router.push('/login')">登录</button>
          <button class="btn btn-primary btn-sm" @click="$router.push('/register')">注册</button>
        </template>
      </div>
    </header>

    <!-- ===== 主体四分区 ===== -->
    <div class="editor-body">
      <!-- 左侧资源栏 -->
      <aside class="panel-left" :class="{ collapsed: leftCollapsed }">
        <div class="panel-left-header">
          <span class="panel-title">{{ leftPanelTitle }}</span>
          <button class="panel-toggle" @click="leftCollapsed = !leftCollapsed">
            <span v-if="!leftCollapsed">◁</span>
            <span v-else>▷</span>
          </button>
        </div>
        <div class="panel-left-content" v-if="!leftCollapsed">
          <router-view name="sidebar" />
        </div>
      </aside>

      <!-- 中部 70% 编辑区 -->
      <main class="editor-main">
        <router-view />
      </main>

      <!-- 右侧 30% 参数/信息面板 -->
      <aside class="panel-right" :class="{ collapsed: rightCollapsed }">
        <div class="panel-right-header">
          <span class="panel-title">{{ rightPanelTitle }}</span>
          <button class="panel-toggle" @click="rightCollapsed = !rightCollapsed">
            <span v-if="!rightCollapsed">▷</span>
            <span v-else>◁</span>
          </button>
        </div>
        <div class="panel-right-content" v-if="!rightCollapsed">
          <router-view name="inspector" />
        </div>
      </aside>
    </div>

    <!-- ===== 底部状态栏 ===== -->
    <footer class="statusbar">
      <div class="status-left">
        <span class="status-item">
          <span class="status-dot" :class="{ online: isLoggedIn }"></span>
          {{ isLoggedIn ? shortName || '会员' : '游客' }}
        </span>
        <span class="status-sep">|</span>
        <span class="status-item">剩余 {{ creditDisplay }}</span>
        <span class="status-sep">|</span>
        <span class="status-item">{{ authHint }}</span>
      </div>
      <div class="status-right">
        <span class="status-item status-warn">内容仅供学习参考，请遵守法律法规</span>
      </div>
    </footer>
  </div>
</template>

<script>
export default {
  name: 'AppLayout',
  data() {
    return {
      activeModule: 'script',
      leftCollapsed: false,
      rightCollapsed: false,
      creditBalance: 0,
      userTier: '',
      username: '',
      token: '',
      showUserMenu: false,

      topTabs: [
        { key: 'script',    icon: '📝', label: '分集剧本' },
        { key: 'commerce',  icon: '🛒', label: '带货分镜' },
        { key: 'corporate', icon: '🏢', label: '宣传片' },
        { key: 'analysis',  icon: '🔍', label: '镜头解析' },
      ]
    }
  },
  computed: {
    isLoginPage() {
      return ['/login', '/register'].includes(this.$route.path)
    },
    isLoggedIn() {
      return !!this.token
    },
    creditDisplay() {
      if (!this.token) return '—次'
      return `${this.creditBalance}次`
    },
    tierLabel() {
      const map = { 'basic': '基础', 'pro': '专业', 'enterprise': '企业' }
      const tier = this.userTier || (this.token ? '基础' : '')
      return map[tier] || tier || ''
    },
    authHint() {
      if (!this.token) return '游客模式 · 部分功能受限'
      if (this.creditBalance <= 0) return '次数已用完 · 请续费'
      return ''
    },
    userInitial() {
      const name = this.username || localStorage.getItem('username') || 'U'
      return name.charAt(0).toUpperCase()
    },
    shortName() {
      const name = this.username || localStorage.getItem('username') || ''
      return name.length > 6 ? name.slice(0, 6) + '…' : name
    },
    leftPanelTitle() {
      const titles = {
        script:    '创作资源',
        commerce:  '产品卖点',
        corporate: '品牌档案',
        analysis:  '素材列表',
      }
      return titles[this.activeModule] || '资源'
    },
    rightPanelTitle() {
      const titles = {
        script:    '剧本预览',
        commerce:  '分镜参数',
        corporate: '文案预览',
        analysis:  '拆解详情',
      }
      return titles[this.activeModule] || '详情'
    }
  },
  watch: {
    '$route'(to) {
      // 根据路由切换活跃模块
      if (to.path === '/' || to.path.startsWith('/workbench')) {
        const q = to.query.module || 'script'
        this.activeModule = q
      }
    }
  },
  methods: {
    switchModule(key) {
      this.activeModule = key
      this.$router.push({ path: '/', query: { module: key } }).catch(() => {})
    },
    goProfile() {
      this.showUserMenu = false
      this.$router.push('/profile')
    },
    goHistory() {
      this.showUserMenu = false
      this.$router.push('/history')
    },
    async loadBalance() {
      try {
        if (!this.token) return
        const r = await fetch('/api/v1/billing/balance', {
          headers: { 'Authorization': 'Bearer ' + this.token }
        }).then(r => r.json())
        if (r.success) this.creditBalance = r.data.balance
      } catch (e) { /* 静默注册 */ }
    },
    async loadUserInfo() {
      try {
        if (!this.token) return
        const r = await fetch('/api/v1/auth/me', {
          headers: { 'Authorization': 'Bearer ' + this.token }
        }).then(r => r.json())
        if (r.success) {
          this.username = r.data.username || ''
          this.userTier = r.data.tier || ''
          localStorage.setItem('username', this.username)
        }
      } catch (e) { /* 静默注册 */ }
    },
    logout() {
      localStorage.removeItem('token')
      localStorage.removeItem('username')
      this.token = ''
      this.username = ''
      this.creditBalance = 0
      this.$router.push('/login')
      this.showUserMenu = false
    },
    handleClickOutside(e) {
      if (this.$refs.userRef && !this.$refs.userRef.contains(e.target)) {
        this.showUserMenu = false
      }
    }
  },
  mounted() {
    this.token = localStorage.getItem('token') || ''
    if (this.token) {
      this.loadBalance()
      this.loadUserInfo()
    }
    document.addEventListener('click', this.handleClickOutside)
  },
  beforeUnmount() {
    document.removeEventListener('click', this.handleClickOutside)
  }
}
</script>

<style scoped>
