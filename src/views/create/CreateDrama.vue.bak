.clapper-scene { font-size:12px; color:var(--text-secondary); margin-top:12px; }
@keyframes clapIn { 0%{opacity:0;transform:scale(0.8)} 100%{opacity:1;transform:scale(1)} }
/* 主舞台 */
.main-stage { position:relative; z-index:1; height:100%; display:flex; flex-direction:column; }
