<template>
<div class="hollywood-studio">
  <canvas ref="pc" class="particle-canvas"></canvas>
  <!-- 打板开场 -->
  <div v-if="showClapper" class="clapper-overlay">
    <div class="clapper-board">
      <div class="clapper-top"></div>
      <div class="clapper-bottom">
        <div class="clapper-title">AI面短剧</div>
        <div class="clapper-sub">PRODUCTION STUDIO</div>
        <div class="clapper-scene">SCENE 001 · TAKE 01</div>
      </div>
    </div>
  </div>
  <!-- 主舞台 -->
  <div v-show="!showClapper" class="main-stage" :class="{ 'monitor-open': showMonitor }">
    <div class="top-bar">
      <div class="led-box"><span class="led-digit">{{ pad(stageIdx+1) }}</span><span class="led-slash">/</span><span class="led-digit">{{ pad(totalStages) }}</span></div>
      <div class="bar-label">AI面短剧 · 制片流程</div>
      <div class="bar-status">{{ statusLabel }}</div>
      <div class="bar-actions">
        <button v-if="previewUrl" class="bar-btn cinema-btn" @click="openCinema">
          <span>🎬</span> 全屏预览
        </button>
        <button class="bar-btn monitor-btn" :class="{on:monitorOpen}" @click="toggleMonitor">
          <span>📺</span> 监视器
        </button>
      </div>
    </div>

    <!-- 🔴 余额胶囊 + 成本估算 -->
    <div class="billing-bar">
      <div class="balance-capsule" :class="{ 'balance-low': balanceData.balance < estimatedCost }" @click="showRechargeModal = true">
        <span class="balance-icon">💰</span>
        <span class="balance-amount">¥{{ balanceData.balance.toFixed(2) }}</span>
        <span class="balance-label">余额</span>
      </div>
      <div v-if="estimatedCost > 0" class="cost-tag">
        <span class="cost-icon">📊</span>
        <span class="cost-amount">预估 ¥{{ estimatedCost.toFixed(2) }}</span>
      </div>
      <div v-if="balanceData.balance < estimatedCost && estimatedCost > 0" class="insufficient-warning">
        ⚠️ 余额不足，还差 ¥{{ (estimatedCost - balanceData.balance).toFixed(2) }}
      </div>
    </div>
    <!-- 充值弹窗 -->
    <div v-if="showRechargeModal" class="recharge-modal-overlay" @click.self="showRechargeModal = false">
      <div class="recharge-modal">
        <h3>💰 充值余额</h3>
        <p class="recharge-sub">当前余额: ¥{{ balanceData.balance.toFixed(2) }}</p>
        <div class="recharge-options">
          <button
            v-for="opt in rechargeOptions"
            :key="opt"
            class="recharge-opt-btn"
            :class="{ active: rechargeAmount === opt }"
            @click="rechargeAmount = opt"
          >¥{{ opt }}</button>
        </div>
        <div class="recharge-actions">
          <button class="recharge-confirm-btn" :disabled="recharging" @click="handleRecharge">
            {{ recharging ? '充值中...' : `确认充值 ¥${rechargeAmount}` }}
          </button>
          <button class="recharge-cancel-btn" @click="showRechargeModal = false">取消</button>
        </div>
      </div>
    </div>
    <div class="workspace">
      <!-- 左侧步骤胶片卡 -->
      <div class="left-cards">
        <div v-for="(s,i) in stageList" :key="s.id" class="film-card" :class="{active:i===stageIdx, done:s.status==='completed', failed:s.status==='failed'}" @click="jumpTo(i)">
          <div class="film-perf-top"></div>
          <div class="card-inner">
            <div class="card-num">{{ pad(i+1) }}</div>
            <div class="card-name">{{ s.label }}</div>
            <div class="card-icon">{{ s.icon||'▶' }}</div>
            <div class="card-dot" :class="{ok:s.status==='completed',err:s.status==='failed',run:s.status==='running'}"></div>
          </div>
          <div class="film-perf-bottom"></div>
        </div>
      </div>
      <!-- 中心工作区 -->
      <div class="center-stage">
        <div class="stage-header">
          <h2>{{ currentStage?.label || '选择阶段' }}</h2>
          <p>{{ currentStage?.desc || '' }}</p>
        </div>
        <!-- v5: 管道进度面板 -->
        <div v-if="pipelineRunning || pipelineFinished" class="pipeline-progress-panel">
          <!-- 顶部状态 -->
          <div class="ppp-header" :class="pipelineFinished ? 'ppp-done' : pipelineFailed ? 'ppp-retrying' : ''">
            <div class="ppp-header-icon">
              <span v-if="pipelineFailed">⚠️</span>
              <span v-else-if="pipelineFinished">✅</span>
              <span v-else class="spinning-icon">🔄</span>
            </div>
            <div class="ppp-header-text">
              <h3 v-if="pipelineFinished">✅ 生成完成！</h3>
              <h3 v-else-if="pipelineFailed">⚠️ 自动重试中，请稍候...</h3>
              <h3 v-else>🔄 生成中...</h3>
              <p>{{ pipelineStatusText }}</p>
            </div>
            <div v-if="pipelineFinished && pipelineVideoUrl" class="ppp-header-actions">
              <button class="ppp-btn cinema-btn" @click="openPipelineVideo">🎬 观看成片</button>
            </div>
          </div>
          <!-- 阶段列表 -->
          <div class="ppp-stages">
            <div
              v-for="s in pipelineStages"
              :key="s.stage"
              class="ppp-stage-row"
              :class="{
                'ppp-active': s.status === 'running',
                'ppp-done': s.status === 'completed',
                'ppp-failed': s.status === 'failed'
              }"
            >
              <span class="ppp-stage-icon">
                <span v-if="s.status === 'completed'">✅</span>
                <span v-else-if="s.status === 'running'" class="spinning-icon">🔄</span>
                <span v-else-if="s.status === 'failed'">❌</span>
                <span v-else>⏳</span>
              </span>
              <span class="ppp-stage-label">{{ s.label }}</span>
              <span v-if="s.error" class="ppp-stage-error" :title="s.error">
                {{ s.error.substring(0, 40) }}{{ s.error.length > 40 ? '...' : '' }}
              </span>
              <span v-else-if="s.status === 'completed'" class="ppp-stage-ok">OK</span>
            </div>
          </div>
          <!-- 视频预览 -->
          <div v-if="pipelineFinished && pipelineVideoUrl" class="ppp-video-section">
            <video
              v-if="!videoError"
              :src="pipelineVideoUrl"
              controls
              autoplay
              muted
              class="ppp-video"
              @error="videoError = true"
            ></video>
            <div v-else class="ppp-video-fallback">
              <p>视频加载失败，请尝试直接访问:</p>
              <a :href="pipelineVideoUrl" target="_blank">{{ pipelineVideoUrl }}</a>
            </div>
          </div>
        </div>
        <!-- 普通模式：步骤组件 -->
        <div v-if="!pipelineRunning && !pipelineFinished" class="stage-content">
          <button
            v-if="stageIdx>0"
            class="one-click-btn"
            :disabled="oneClickLoading"
            @click="handleOneClickGenerate"
          >
            <span v-if="oneClickLoading" class="spinner"></span>
            {{ oneClickLoading ? '🔄 生成中...' : '⚡ 一键生成' }}
            <span v-if="!oneClickLoading" class="one-click-hint">不想修改？AI 一键生成全剧</span>
          </button>
          <div v-if="genError" class="gen-error-banner">
        <span>⚠️ {{ genError }}</span>
        <button @click="genError = ''; errorMsg = ''" class="gen-error-close">✕</button>
      </div>
          <component :is="currentComp" :projectId="taskId" :task-id="taskId" :scene-data="sceneData" :stage-id="currentStage?.id" @next="handleNext" @retry="handleRetry" @error="handleComponentError" />
        </div>
      </div>
    </div>
  </div>
</div>
</template>
<script setup>
import { ref, computed, inject, onMounted, onUnmounted, watch } from 'vue'
import request from '@/utils/request'
import { useRouter, useRoute } from 'vue-router'
import { safeGetLS, safeSetLS, safeGetJSON, safeSetJSON, acquireLock, releaseLock } from '@/utils/lsLock'
// 组件导入
import ThemeSelector from '@/components/creation/ThemeSelector.vue'
import ScriptGenerator from '@/components/creation/ScriptGenerator.vue'
import CharacterBuilder from '@/components/creation/CharacterBuilder.vue'
import storage from '@/utils/storage'
import StoryboardEditor from '@/components/creation/StoryboardEditor.vue'
// REMOVED: import SceneGenerator from '@/components/creation/SceneGenerator.vue'
import AudioMixer from '@/components/creation/AudioMixer.vue'
import VideoRenderer from '@/components/creation/VideoRenderer.vue'
const router = useRouter()
const route = useRoute()
// 从 App.vue 注入监视器和全屏控制
const showMonitor = inject('showMonitor', ref(false))
const previewHtml = inject('previewHtml', ref(''))
const previewData = inject('previewData', ref(null))
const fullscreenVideo = inject('fullscreenVideo', ref(null))
// 阶段定义
const stageList = [
  { id:'theme_selection', label:'上传剧本', icon:'📤', desc:'粘贴剧本或输入梗概' },
  { id:'director_analysis', label:'导演分析', icon:'🎬', desc:'AI分析剧本结构' },
  { id:'script_creation', label:'剧本润色', icon:'📝', desc:'AI润色优化剧本' },
  { id:'character_design', label:'角色设计', icon:'👤', desc:'提取并设计角色形象' },
  { id:'storyboard_generation', label:'分镜生成', icon:'🎬', desc:'创建分镜脚本' },
  { id:'voice_synthesis', label:'配音合成', icon:'🎙️', desc:'角色配音制作' },
  { id:'subtitle_generation', label:'字幕生成', icon:'💬', desc:'自动生成字幕' },
  { id:'bgm_composition', label:'BGM配乐', icon:'🎵', desc:'背景音乐搭配' },
  { id:'video_generation', label:'视频生成', icon:'🎥', desc:'AI生成视频片段' },
  { id:'video_composition', label:'视频合成', icon:'🎞️', desc:'最终合成导出' },
]
const totalStages = computed(() => stageList.length)
// 组件映射
const compMap = {
  theme_selection: ThemeSelector,
  director_analysis: ScriptGenerator,
  script_creation: ScriptGenerator,
  script_generation: ScriptGenerator,
  character_design: CharacterBuilder,
  storyboard_generation: StoryboardEditor,
  voice_synthesis: AudioMixer,
  bgm_composition: AudioMixer,
  subtitle_generation: AudioMixer,
  video_generation: VideoRenderer,
  video_composition: VideoRenderer,
  video_rendering: VideoRenderer,
}
// v5: 管道进度状态
const pipelineRunning = ref(false)
const pipelineFinished = ref(false)
const pipelineFailed = ref(false)
const pipelineStages = ref([])
const pipelineVideoUrl = ref('')
const pipelineStatusText = ref('')
const currentPipelineStage = ref('')
const oneClickLoading = ref(false)
const videoError = ref(false)
const pipelineProjectId = ref('')
// ── 账单相关状态 ──
const balanceData = ref({ balance: 0, total_charged: 0, total_spent: 0 })
const estimatedCost = ref(0)
const showRechargeModal = ref(false)
const rechargeAmount = ref(10)
const recharging = ref(false)
const rechargeOptions = [10, 20, 50, 100]
let pollTimer = null
let pollFailCount = 0
const MAX_POLL_FAILS = 5
let animationFrameId = null
let resizeHandler = null
let polling = false
// 状态
const taskId = ref(route.query.task_id || generateTaskId())
const stageIdx = ref(getInitialStage())
function getInitialStage() {
  const qs = route.query.stage
  if (qs !== undefined) return parseInt(qs) || 0
  try {
    const state = JSON.parse(localStorage.getItem('__CREATE_STATE__') || '{}')
    if (state._lastStage !== undefined) return state._lastStage
  } catch(e) {}
  return 0
}
const showClapper = ref(true)
const previewUrl = ref(null)
const monitorOpen = ref(false)
const sceneData = ref([])
const currentStage = computed(() => stageList[stageIdx.value])
const currentComp = computed(() => compMap[currentStage.value?.id] || ScriptGenerator)
const statusLabel = computed(() => {
  const s = currentStage.value; if(!s) return '就绪'
  return `正在处理: ${s.label}`
})
function pad(n) { return String(n).padStart(2,'0') }
function generateTaskId() { return 'task_' + Date.now() + '_' + Math.random().toString(36).slice(2,8) }
// ─── v5: 一键生成全剧（改造版）───
async function handleOneClickGenerate() {
  try {
    oneClickLoading.value = true
    // 收集 localStorage 数据（加锁避免与 ThemeSelector 等组件并发读写）
    await acquireLock('__DRAMA_STATE__')
    let scriptText, genre, characters, title
    try {
      scriptText = localStorage.getItem('__DRAMA_SCRIPT__') || ''
      genre = localStorage.getItem('__DRAMA_GENRE__') || ''
      characters = []
      try {
        const charsRaw = localStorage.getItem('__DRAMA_CHARS__')
        if (charsRaw) characters = JSON.parse(charsRaw)
      } catch(e) {}
      // 也尝试从 __CREATE_STATE__ 获取
      try {
        const state = JSON.parse(localStorage.getItem('__CREATE_STATE__') || '{}')
        if (!scriptText && state.script) scriptText = state.script
        if (!genre && state.genre) genre = state.genre
        if (!characters.length && state.characters) characters = state.characters
        if (state.title) title = state.title
      } catch(e) {}
    } finally {
      releaseLock('__DRAMA_STATE__')
    }
    const projectId = taskId.value
    // ── 余额校验 ──
    if (!balanceData.value || !balanceData.value.balance) {
      await fetchBalance()
    }
    if (balanceData.value.balance < estimatedCost.value && estimatedCost.value > 0) {
      showRechargeModal.value = true
      oneClickLoading.value = false
      return
    }
    // 一次性提交 pipeline/start
    const data = await request({ url: '/api/v1/pipeline/start', method: 'POST', data: {
        project_id: projectId,
        script_text: scriptText,
        genre: genre,
        title: title,
        characters: characters,
        max_shots: 8
      } })
    if (!data.success) {
      alert('一键生成失败: ' + (data.message || '未知错误'))
      oneClickLoading.value = false
      return
    }
    pipelineProjectId.value = data.project_id || data.pipeline_id || projectId
    // 如果是续传，有已有进度
    if (data.status === 'resumed' && data.progress && data.progress.length > 0) {
      initPipelineStages(data.progress)
    } else {
      initPipelineStages([])
    }
    // 启动管道
    pipelineRunning.value = true
    pipelineFinished.value = false
    pipelineFailed.value = false
    pollFailCount = 0  // 重置失败计数器
    oneClickLoading.value = false
    // 开始轮询
    startPolling()
  } catch(e) {
    alert('一键生成请求失败: ' + e.message)
    console.error('handleOneClickGenerate error:', e)
    oneClickLoading.value = false
  }
}
function initPipelineStages(existingProgress) {
  const serverStages = [
    { stage: 'director', label: '导演分析', icon: '🎬' },
    { stage: 'script', label: '剧本创作', icon: '📝' },
    { stage: 'character', label: '角色设计', icon: '🎭' },
    { stage: 'storyboard', label: '分镜生成', icon: '🎞️' },
    { stage: 'cinematographer', label: '摄影指导', icon: '📷' },
    { stage: 'wardrobe', label: '服化道设计', icon: '👗' },
    { stage: 'sfx', label: '特效设计', icon: '✨' },
    { stage: 'tts', label: '配音合成', icon: '🎙️' },
    { stage: 'subtitle', label: '字幕生成', icon: '💬' },
    { stage: 'bgm', label: 'BGM配乐', icon: '🎵' },
    { stage: 'video', label: '视频生成', icon: '🎬' },
    { stage: 'composite', label: '视频合成', icon: '📺' },
  ]
  const existingMap = {}
  if (existingProgress && existingProgress.length) {
    for (const s of existingProgress) {
      existingMap[s.stage] = s.status
    }
  }
  pipelineStages.value = serverStages.map(s => ({
    ...s,
    status: existingMap[s.stage] || 'pending',
    error: '',
  }))
}
async function pollProgress() {
  if (!pipelineProjectId.value) return
  try {
  if (polling) return
  polling = true
    const result = await request({ url: `/api/v1/pipeline/progress/${pipelineProjectId.value}` })
    if (!result.success) {
      pollFailCount++
      console.warn(`[轮询] 请求失败 (${pollFailCount}/${MAX_POLL_FAILS}):`, result.message || 'unknown')
      if (pollFailCount >= MAX_POLL_FAILS) {
        console.error('[轮询] 连续失败已达上限，停止轮询')
        pipelineFailed.value = true
        pipelineStatusText.value = '网络异常，请刷新页面重试'
        stopPolling()
      }
      return
    }
    // 成功则重置失败计数
    pollFailCount = 0
    const data = result.data
    // 更新阶段状态
    if (data.stages && data.stages.length > 0) {
      // 保留之前的状态对比
      const hadFailed = pipelineStages.value.some(s => s.status === 'failed')
      let hasNewFailure = false
      pipelineStages.value = data.stages.map(s => {
        const old = pipelineStages.value.find(o => o.stage === s.stage)
        if (!old || old.status !== s.status) {
          if (s.status === 'failed' && (!old || old.status !== 'failed')) {
            hasNewFailure = true
          }
        }
        return {
          stage: s.stage,
          label: s.label || s.stage,
          icon: s.icon || '❓',
          status: s.status,
          error: s.error || '',
        }
      })
      currentPipelineStage.value = data.current_stage || ''
    }
    // 检查项目状态
    const projectStatus = result.project_status || ''
    if (data.finished) {
      // 全部完成！
      pipelineFinished.value = true
      pipelineRunning.value = false
      pipelineFailed.value = false
      if (data.final_video_url) {
        pipelineVideoUrl.value = data.final_video_url
        previewUrl.value = data.final_video_url
      }
      pipelineStatusText.value = '短剧生成完成！请点击"观看成片"查看。'
      // 标记左侧所有步骤完成
      for (let i = 0; i < stageList.length; i++) {
        stageList[i].status = 'completed'
      }
      stageIdx.value = stageList.length - 1
      stopPolling()
      return
    }
    if (data.has_failed) {
      pipelineFailed.value = true
      pipelineStatusText.value = '部分阶段失败，系统将自动重试...'
    } else if (projectStatus === 'pending_retry') {
      pipelineFailed.value = true
      pipelineStatusText.value = '自动重试中，请稍候...'
    }
    if (pipelineRunning.value) {
      const runningCount = pipelineStages.value.filter(s => s.status === 'running').length
      const completedCount = pipelineStages.value.filter(s => s.status === 'completed').length
      const totalCount = pipelineStages.value.length
      if (runningCount > 0) {
        pipelineStatusText.value = `进度: ${completedCount}/${totalCount} 阶段完成，${runningCount} 阶段进行中`
      } else if (pipelineFailed.value) {
        pipelineStatusText.value = '部分阶段失败，系统将自动重试...'
      } else {
        pipelineStatusText.value = `进度: ${completedCount}/${totalCount} 阶段完成`
      }
    }
  } catch (e) {
    pollFailCount++
    console.warn(`[轮询] 异常 (${pollFailCount}/${MAX_POLL_FAILS}):`, e.message || e)
    if (pollFailCount >= MAX_POLL_FAILS) {
      console.error('[轮询] 连续失败已达上限，停止轮询')
      pipelineFailed.value = true
      pipelineStatusText.value = '网络异常，请刷新页面重试'
      stopPolling()
    }
  } finally {
    polling = false
  }
}
function startPolling() {
  stopPolling()
  pollFailCount = 0
  pollTimer = setInterval(pollProgress, 3000)
}
function stopPolling() {
  if (pollTimer) {
    clearInterval(pollTimer)
    pollTimer = null
  }
}
function openPipelineVideo() {
  if (pipelineVideoUrl.value) {
    fullscreenVideo.value = pipelineVideoUrl.value
  }
}
// 监听 fullscreenVideo 变化，确保全屏
watch(fullscreenVideo, (v) => {
  if (v) {
    showMonitor.value = true
    monitorOpen.value = true
  }
})
// ─── 后端stage→前端id映射表 ───
const BACKEND_TO_FRONTEND = {
  'director':         'director_analysis',
  'script':           'script_creation',
  'character':        'character_design',
  'storyboard':       'storyboard_generation',
  'cinematographer':  'director_analysis',
  'wardrobe':         'character_design',
  'scene':            'storyboard_generation',
  'sfx':              'storyboard_generation',
  'tts':              'voice_synthesis',
  'subtitle':         'subtitle_generation',
  'bgm':              'bgm_composition',
  'video':            'video_generation',
  'composite':        'video_composition',
}
// ─── 断点续接 ───
async function restoreFromProject(projectId) {
  try {
    const data = await request({ url: `/api/v1/projects/${projectId}/progress` })
    if (!data.success) {
      console.warn('断点续接: 项目不存在', projectId)
      return
    }
    // 恢复剧本/题材/角色到 localStorage（加锁避免并发写入竞态）
    await acquireLock('__DRAMA_STATE__')
    try {
      if (data.script) localStorage.setItem('__DRAMA_SCRIPT__', data.script)
      if (data.genre) localStorage.setItem('__DRAMA_GENRE__', data.genre)
      if (data.characters) localStorage.setItem('__DRAMA_CHARS__', JSON.stringify(data.characters))
      if (data.title) {
        try {
          const state = JSON.parse(localStorage.getItem('__CREATE_STATE__') || '{}')
          state.title = data.title
          localStorage.setItem('__CREATE_STATE__', JSON.stringify(state))
        } catch(e) {}
      }
    } finally {
      releaseLock('__DRAMA_STATE__')
    }
    // v5: 检查管道进度（含已完成的管道，用于恢复分镜/场景图数据）
    let pipelineStagesData = null
    try {
      const progData = await request({ url: `/api/v1/pipeline/progress/${projectId}` })
      if (progData.success && progData.data && progData.data.stages && progData.data.stages.length > 0) {
        const stages = progData.data.stages
        pipelineStagesData = stages
        const hasActive = stages.some(s => s.status === 'running' || s.status === 'pending')
        const anyCompleted = stages.some(s => s.status === 'completed')
        if (hasActive || (anyCompleted && !progData.data.finished)) {
          // 有进行中的管道，直接显示进度面板
          pipelineProjectId.value = data.project_id || data.pipeline_id || projectId
          pipelineRunning.value = true
          pipelineStages.value = stages.map(s => ({
            stage: s.stage,
            label: s.label || s.stage,
            icon: s.icon || '\u2753',
            status: s.status,
            error: s.error || '',
          }))
          pipelineFinished.value = progData.data.finished
          if (progData.data.final_video_url) {
            pipelineVideoUrl.value = progData.data.final_video_url
            previewUrl.value = progData.data.final_video_url
          }
          pollFailCount = 0
          startPolling()
          return
        }
      }
    } catch(e) {
      console.warn('断点续接: 管道进度检查失败', e.message || e)
    }
    // ─── 从管道数据恢复分镜 + 场景图 ───
    if (pipelineStagesData) {
      const storyboardStage = pipelineStagesData.find(s => s.stage === 'storyboard')
      const sceneStage = pipelineStagesData.find(s => s.stage === 'scene')
      // 从 storyboard stage 取出 shots
      const sbData = (storyboardStage && storyboardStage.data) ? storyboardStage.data : {}
      let shots = sbData.shots || sbData.scenes || []
      // 从 scene stage 取出 scene_images 并注入到对应 shot
      if (shots.length > 0 && sceneStage && sceneStage.data) {
        const scData = sceneStage.data
        const sceneImages = scData.images || scData.scene_images || []
        if (sceneImages.length > 0) {
          shots = shots.map((shot, i) => ({
            ...shot,
            scene_image: shot.scene_image
              || (sceneImages[i] && (sceneImages[i].url || sceneImages[i].image_url || (typeof sceneImages[i] === 'string' ? sceneImages[i] : '')))
              || '',
          }))
        }
      }
      // 写入 localStorage — StoryboardEditor.loadStoryboardData() 从这里读取
      if (shots.length > 0) {
        await safeSetLS('__DRAMA_STORYBOARD__', JSON.stringify({ shots }))
      }
    }
    // ─── 根据 steps 恢复到对应步骤 ───
    const steps = data.steps || []
    let lastCompletedIdx = -1
    let storyboardIdx = -1
    for (let i = 0; i < stageList.length; i++) {
      if (stageList[i].id === 'storyboard_generation') storyboardIdx = i
      // 用映射表 + 直接匹配 + label 兜底
      const step = steps.find(s =>
        s.key === stageList[i].id
        || BACKEND_TO_FRONTEND[s.key] === stageList[i].id
        || s.label === stageList[i].label
      )
      if (step && (step.status === 'done' || step.status === 'completed')) {
        stageList[i].status = 'completed'
        lastCompletedIdx = i
      }
    }
    // 决定跳到哪个步骤
    // 1) 分镜步骤已完成 → 跳到分镜步骤（用户能看到已生成的图）
    if (storyboardIdx >= 0 && stageList[storyboardIdx]?.status === 'completed') {
      stageIdx.value = storyboardIdx
    }
    // 2) 分镜步骤存在但未完成 → 跳到分镜步骤让用户继续
    else if (storyboardIdx >= 0) {
      const storyboardStep = steps.find(s =>
        BACKEND_TO_FRONTEND[s.key] === 'storyboard_generation'
        || s.key === 'storyboard_generation'
      )
      if (storyboardStep && (storyboardStep.status === 'pending' || storyboardStep.status === 'in_progress' || storyboardStep.status === 'busy')) {
        stageIdx.value = storyboardIdx
      } else if (lastCompletedIdx >= 0 && lastCompletedIdx < stageList.length - 1) {
        stageIdx.value = lastCompletedIdx + 1
      } else if (lastCompletedIdx === -1) {
        stageIdx.value = 0
      } else {
        stageIdx.value = stageList.length - 1
      }
    }
    // 3) 默认：跳到下一个未完成步骤
    else if (lastCompletedIdx >= 0 && lastCompletedIdx < stageList.length - 1) {
      stageIdx.value = lastCompletedIdx + 1
    } else if (lastCompletedIdx === -1) {
      stageIdx.value = 0
    } else {
      stageIdx.value = stageList.length - 1
    }
    // 保存恢复状态
    try {
      const state = JSON.parse(localStorage.getItem('__CREATE_STATE__') || '{}')
      state._lastStage = stageIdx.value
      localStorage.setItem('__CREATE_STATE__', JSON.stringify(state))
    } catch(e) {}
  } catch(e) {
    console.error('断点续接失败:', e)
  }
}// ─── 账单相关：获取余额 ───
async function fetchBalance() {
  try {
    const res = await request({ url: '/api/v1/billing/balance', method: 'GET' })
    if (res.success) {
      balanceData.value = res.data
    }
  } catch(e) {
    console.error('获取余额失败:', e)
  }
}

// ─── 账单相关：获取预估成本 ───
async function fetchEstimate(scriptText, characterCount, sceneCount, durationPerScene) {
  try {
    const res = await request({
      url: '/api/v1/billing/estimate',
      method: 'POST',
      data: {
        script_text: scriptText || '',
        character_count: characterCount || 0,
        scene_count: sceneCount || 0,
        video_duration_per_scene: durationPerScene || 5
      }
    })
    if (res.success && res.data) {
      estimatedCost.value = res.data.estimated_cost_yuan
    }
  } catch(e) {
    console.error('获取预估成本失败:', e)
  }
}

// ─── 账单相关：充值 ───
async function handleRecharge() {
  if (recharging.value) return
  recharging.value = true
  try {
    const res = await request({
      url: '/api/v1/billing/recharge',
      method: 'POST',
      data: { amount: rechargeAmount.value, method: '网页充值' }
    })
    if (res.success) {
      balanceData.value.balance = res.data.balance
      balanceData.value.total_charged = res.data.total_charged
      showRechargeModal.value = false
    } else {
      alert('充值失败: ' + (res.message || '未知错误'))
    }
  } catch(e) {
    alert('充值请求失败: ' + e.message)
  } finally {
    recharging.value = false
  }
}

// 打板动画
onMounted(() => {
  setTimeout(() => showClapper.value = false, 2200)
  // 初始化余额
  fetchBalance()
  // 定期刷新余额
  setInterval(fetchBalance, 30000)
  // B1: 从角色编辑器返回时恢复已编辑的角色数据
  try {
    const savedChars = localStorage.getItem('__DRAMA_CHARS__')
    if (savedChars) {
      const chars = JSON.parse(savedChars)
      const state = JSON.parse(localStorage.getItem('__CREATE_STATE__') || '{}')
      state.characters = chars
      localStorage.setItem('__CREATE_STATE__', JSON.stringify(state))
    }
  } catch(e) {}
  // B3: 断点续接 - 检查 URL 参数
  const continueId = route.query.continue_project_id
  if (continueId) {
    restoreFromProject(continueId)
  }
  // 粒子背景
  const canvas = document.querySelector('.particle-canvas')
  if (canvas) initParticles(canvas)
  resizeHandler = () => { if (canvas) resizeCanvas(canvas) }; window.addEventListener('resize', resizeHandler)
})
onUnmounted(() => {
  stopPolling()
  if (animationFrameId) {
    cancelAnimationFrame(animationFrameId)
    animationFrameId = null
  }
  if (resizeHandler) {
    window.removeEventListener('resize', resizeHandler)
    resizeHandler = null
  }
})
function initParticles(canvas) {
  resizeCanvas(canvas)
  const ctx = canvas.getContext('2d')
  const particles = Array.from({length:60},()=>({
    x:Math.random()*canvas.width, y:Math.random()*canvas.height,
    vx:(Math.random()-.5)*0.3, vy:(Math.random()-.5)*0.3,
    size:Math.random()*2+0.5, alpha:Math.random()*0.4+0.1
  }))
  function draw() {
    ctx.clearRect(0,0,canvas.width,canvas.height)
    particles.forEach(p => {
      p.x+=p.vx;p.y+=p.vy
      if(p.x<0)p.x=canvas.width;if(p.x>canvas.width)p.x=0
      if(p.y<0)p.y=canvas.height;if(p.y>canvas.height)p.y=0
      ctx.beginPath();ctx.arc(p.x,p.y,p.size,0,Math.PI*2)
      ctx.fillStyle=`rgba(138,43,226,${p.alpha})`;ctx.fill()
    })
    animationFrameId = requestAnimationFrame(draw)
  }
  draw()
}
function resizeCanvas(c) { c.width=window.innerWidth; c.height=window.innerHeight }
// 阶段跳转
function jumpTo(i) {
  if (i > stageIdx.value && stageList[i-1]?.status !== 'completed') return
  stageIdx.value = i
}
function handleComponentError(msg) {
  genError.value = msg || '操作失败，请重试'
  errorMsg.value = msg || '操作失败，请重试'
  console.error('[CreateDrama] component error:', msg)
}
function handleNext(data) {
  if (typeof data === 'string') previewUrl.value = data
  if (data?.video_url) previewUrl.value = data.video_url
  if (Array.isArray(data)) sceneData.value = data
  if (data?.scenes) sceneData.value = data.scenes
  if (data?.preview) { previewData.value = data.preview; showMonitor.value = true }
  stageList[stageIdx.value].status = 'completed'
  if (stageIdx.value < totalStages.value - 1) stageIdx.value++
}
function handleRetry() { stageList[stageIdx.value].status = 'failed' }
// 监视器切换
function toggleMonitor() {
  monitorOpen.value = !monitorOpen.value
  showMonitor.value = monitorOpen.value
}
// 全屏影院
function openCinema() {
  if (previewUrl.value) fullscreenVideo.value = previewUrl.value
}
</script>
<style scoped>
.hollywood-studio { width:100%; height:100vh; background:var(--bg-primary); overflow:hidden; position:relative; color:var(--text-primary); font-family:'Inter','Noto Sans SC',-apple-system,sans-serif; }
