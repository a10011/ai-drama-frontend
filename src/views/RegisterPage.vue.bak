<template>
  <div class="auth-page">
    <div class="auth-card">
      <!-- 头部 -->
      <div class="auth-header">
        <div class="auth-logo">🎬</div>
        <h1>创建账号</h1>
        <p>开始你的短剧创作之旅</p>
      </div>

      <!-- 表单 -->
      <div class="auth-form">
        <div class="field">
          <label>用户名</label>
          <input v-model="username" placeholder="请输入用户名" autocomplete="username" @input="clearError" />
        </div>
        <div class="field">
          <label>邮箱 <span class="optional">选填</span></label>
          <input v-model="email" type="email" placeholder="your@email.com" autocomplete="email" />
        </div>
        <div class="field">
          <label>密码</label>
          <div class="pw-wrap">
            <input v-model="password" :type="showPw?'text':'password'" placeholder="至少6位" autocomplete="new-password" @input="checkPwStrength" />
            <span class="pw-toggle" @click="showPw=!showPw">{{ showPw?'🙈':'👁️' }}</span>
          </div>
          <div class="pw-bar" v-if="password">
            <div class="pw-fill" :class="pwLevel" :style="{width:pwPercent+'%'}"></div>
          </div>
        </div>
        <div class="field">
          <label>确认密码</label>
          <input v-model="confirm" type="password" placeholder="再输一次" autocomplete="new-password" />
        </div>

        <!-- 验证码 -->
        <div class="field">
          <label>验证码</label>
          <div class="captcha-row">
            <input v-model="captchaAnswer" placeholder="计算结果" maxlength="4" @keyup.enter="register" />
            <button class="captcha-btn" @click="refreshCaptcha" :disabled="captchaLoading">
              {{ captchaLoading ? '...' : captchaQuestion || '获取验证码' }}
            </button>
          </div>
        </div>

        <!-- 错误提示 -->
        <div class="auth-error" v-if="error">{{ error }}</div>

        <!-- 提交 -->
        <button class="btn-gold" @click="register" :disabled="loading">
          {{ loading ? '注册中...' : '立即注册' }}
        </button>

        <!-- 底部链接 -->
        <p class="auth-foot">已有账号？<router-link to="/login">立即登录</router-link></p>
      </div>
    </div>
  </div>
</template>

<script>
export default {
  data(){
    return{
      username:'',email:'',password:'',confirm:'',showPw:false,
      captchaQuestion:'',captchaToken:'',captchaAnswer:'',captchaLoading:false,
      loading:false,error:'',pwLevel:'',pwPercent:0
    }
  },
  methods:{
    clearError(){this.error=''},
    checkPwStrength(){
      const p=this.password;let s=0
      if(p.length>=6)s+=25;if(p.length>=10)s+=15
      if(/[A-Z]/.test(p))s+=15;if(/[0-9]/.test(p))s+=15
      if(/[^A-Za-z0-9]/.test(p))s+=15;if(/[a-z]/.test(p))s+=15
      this.pwPercent=Math.min(s,100)
      this.pwLevel=this.pwPercent<40?'weak':this.pwPercent<70?'mid':'strong'
    },
    async refreshCaptcha(){
      this.captchaLoading=true
      try{
        const r=await(await fetch('/api/captcha')).json()
        if(r.success){this.captchaQuestion=r.data.question;this.captchaToken=r.data.token}
      }catch(e){this.error='获取验证码失败'}
      finally{this.captchaLoading=false}
    },
    async register(){
      this.error=''
      if(!this.username.trim()){this.error='请输入用户名';return}
      if(this.username.trim().length<2){this.error='用户名至少2个字符';return}
      if(!this.password){this.error='请输入密码';return}
      if(this.password.length<6){this.error='密码至少6位';return}
      if(this.password!==this.confirm){this.error='两次密码不一致';return}
      if(!this.captchaAnswer.trim()){this.error='请输入验证码';return}

      this.loading=true
      try{
        const r=await(await fetch('/api/v1/auth/register',{
          method:'POST',headers:{'Content-Type':'application/json'},
          body:JSON.stringify({username:this.username.trim(),email:this.email.trim(),password:this.password})
        })).json()
        if(r.success){
          this.error=''
          this.$router.push('/login?registered=1')
        }else{
          this.error=r.detail||r.error||'注册失败'
          this.refreshCaptcha()
        }
      }catch(e){this.error='网络错误，请重试'}
      finally{this.loading=false}
    }
  },
  mounted(){this.refreshCaptcha()}
}
</script>

<style scoped>
/* ===== 页面容器 ===== */
.auth-page{
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  padding:24px;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(196,155,74,0.04) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 20%, rgba(196,155,74,0.03) 0%, transparent 50%),
    #0a0a0a;
}

/* ===== 卡片 ===== */
.auth-card{
  width:100%;max-width:420px;
  background:#171717;border:1px solid #222;border-radius:16px;
  padding:40px 36px 32px;
  box-shadow:0 8px 32px rgba(0,0,0,0.4);
}

/* ===== 头部 ===== */
.auth-header{text-align:center;margin-bottom:28px}
.auth-logo{font-size:40px;margin-bottom:8px}
.auth-header h1{font-size:22px;font-weight:700;color:#e8e4dc;margin-bottom:4px}
.auth-header p{font-size:13px;color:#666}

/* ===== 表单字段 ===== */
.auth-form{display:flex;flex-direction:column;gap:16px}
.field{display:flex;flex-direction:column;gap:6px}
.field label{font-size:13px;font-weight:500;color:#888}
.optional{font-weight:400;color:#555;font-size:11px}

.field input{
  width:100%;padding:11px 14px;
  background:#0a0a0a;border:1px solid #222;border-radius:8px;
  font-size:14px;color:#e8e4dc;outline:none;
  transition:border-color .2s,box-shadow .2s;
}
.field input::placeholder{color:#444}
.field input:focus{border-color:#c49b4a;box-shadow:0 0 0 3px rgba(196,155,74,0.08)}

/* 密码输入框 + 显示切换 */
.pw-wrap{position:relative}
.pw-wrap input{padding-right:42px}
.pw-toggle{
  position:absolute;right:12px;top:50%;transform:translateY(-50%);
  cursor:pointer;font-size:16px;user-select:none;opacity:.7;
}
.pw-toggle:hover{opacity:1}

/* 密码强度条 */
.pw-bar{height:3px;background:#222;border-radius:2px;margin-top:2px;overflow:hidden}
.pw-fill{height:100%;border-radius:2px;transition:width .3s,background .3s}
.pw-fill.weak{background:linear-gradient(90deg,#ef4444,#f87171)}
.pw-fill.mid{background:linear-gradient(90deg,#f59e0b,#fbbf24)}
.pw-fill.strong{background:linear-gradient(90deg,#4ade80,#22c55e)}

/* 验证码行 */
.captcha-row{display:flex;gap:10px}
.captcha-row input{flex:1}
.captcha-btn{
  padding:10px 14px;background:#1a1a1a;border:1px solid #222;border-radius:8px;
  color:#c49b4a;font-size:13px;font-weight:600;cursor:pointer;
  white-space:nowrap;transition:all .15s;min-width:110px;text-align:center;
}
.captcha-btn:hover{border-color:#c49b4a;background:rgba(196,155,74,0.05)}
.captcha-btn:disabled{opacity:.5;cursor:default}

/* 错误提示 */
.auth-error{
  background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);
  color:#ef4444;font-size:13px;padding:10px 14px;border-radius:8px;
}

/* 提交按钮 */
.btn-gold{
  width:100%;padding:12px;
  background:linear-gradient(135deg,#c49b4a,#9a7b2e);
  color:#0a0a0a;border:none;border-radius:10px;
  font-size:15px;font-weight:700;cursor:pointer;
  transition:all .2s;margin-top:4px;
}
.btn-gold:hover{background:linear-gradient(135deg,#d4af6a,#b8963a);transform:translateY(-1px);box-shadow:0 4px 16px rgba(196,155,74,0.3)}
.btn-gold:active{transform:translateY(0)}
.btn-gold:disabled{opacity:.5;cursor:not-allowed;transform:none;box-shadow:none}

/* 底部链接 */
.auth-foot{text-align:center;font-size:13px;color:#555;margin-top:4px}
.auth-foot a{color:#c49b4a;text-decoration:none;font-weight:500}
.auth-foot a:hover{text-decoration:underline}
</style>
