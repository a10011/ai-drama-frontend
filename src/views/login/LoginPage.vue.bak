<template>
<div class="login-page">
  <div class="login-card">
    <div class="login-hd">
      <div class="logo"><span class="logo-icon">🎬</span><span class="logo-text">AI面短剧 STUDIOS</span></div>
      <h2>登录你的创作空间</h2>
    </div>
    <el-form :model="form" label-position="top" class="login-form" @keyup.enter="login">
      <el-form-item label="邮箱/手机号">
        <el-input v-model="form.username" placeholder="请输入邮箱或手机号" />
      </el-form-item>
      <el-form-item label="密码">
        <el-input v-model="form.password" type="password" placeholder="请输入密码" show-password />
      </el-form-item>
      <el-form-item label="验证码">
        <div class="captcha-row">
          <el-input v-model="form.captcha" placeholder="计算结果" class="captcha-input" />
          <div class="captcha-box" @click="refreshCaptcha">
            <span>{{ captchaText }}</span>
          </div>
        </div>
      </el-form-item>
      <el-form-item>
        <button class="btn-login" :disabled="loading" @click="login">
          <span v-if="loading">登录中...</span>
          <span v-else>登录 / 注册</span>
        </button>
      </el-form-item>
    </el-form>
    <div class="login-ft"><span>输入账号密码，新用户自动注册</span></div>
  </div>
</div>
</template>

<script setup>
import {ref,reactive} from 'vue'
import {useRouter} from 'vue-router'
import request from '@/utils/request'
import {ElMessage} from 'element-plus'
const router=useRouter()
const form=reactive({username:'',password:'',captcha:'',captcha_token:''})
const loading=ref(false)
const captchaText=ref('?+?=?')
async function refreshCaptcha(){
  try{
    const r=await request({url:'/api/captcha',method:'GET'})
    captchaText.value=r.data?.question||'?+?=?'
    form.captcha_token = r.data?.token||''
  }catch(e){captchaText.value='?+?=?'}
}
async function login(){
  if(!form.username||!form.password){ElMessage.warning('请填写账号和密码');return}
  loading.value=true
  try{
    const r=await request({url:'/api/login',method:'POST',data:{username:form.username,password:form.password,captcha_token:form.captcha_token,captcha_answer:form.captcha}})
    if(r.success){
      const token=r.data?.access_token||r.data?.token
      if(token){
        localStorage.setItem('token',token)
        // 清空上一个账号的创作缓存
        for(let k of Object.keys(localStorage)){
          if(k.startsWith('__DRAMA')||k.startsWith('__CREATE')||k.startsWith('__PREVIEW')||k.startsWith('__PIPELINE')){ localStorage.removeItem(k) }
        }
      }
      router.push('/create')
    }else{ElMessage.error(r.error||r.detail||'登录失败')}
  }catch(e){ElMessage.error(e?.response?.data?.detail||e?.message||'网络错误，请检查连接')}
  loading.value=false
}
</script>

<style scoped>
.login-page{min-height:100vh;background:#0a0a0a;display:flex;align-items:center;justify-content:center;padding:20px}
.login-card{width:420px;max-width:100%;background:#111;border:1px solid #222;border-radius:16px;padding:40px}
.login-hd{text-align:center;margin-bottom:30px}
.logo{display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:12px}
.logo-icon{font-size:28px}.logo-text{font-family:Consolas,monospace;color:#c49b4a;font-size:14px;letter-spacing:.06em}
.login-hd h2{color:#e8e4dc;font-family:Consolas,monospace;font-size:20px;margin:0}
.login-form :deep(.el-form-item__label){color:#888!important;font-family:Consolas,monospace;font-size:12px!important}
.login-form :deep(.el-input__wrapper){background:#151515!important;border:1px solid #222!important;box-shadow:none!important;border-radius:6px!important}
.login-form :deep(.el-input__wrapper:hover){border-color:#c49b4a!important}
.login-form :deep(.el-input__inner){color:#e8e4dc!important}
.captcha-row{display:flex;gap:10px}.captcha-input{flex:1}
.captcha-box{background:#151515;border:1px solid #222;border-radius:6px;padding:8px 14px;color:#c49b4a;font-family:Consolas,monospace;cursor:pointer;font-size:14px;min-width:100px;display:flex;align-items:center;justify-content:center}
.btn-login{width:100%;background:linear-gradient(135deg,#c49b4a,#9a7b2e);color:#0a0a0a;border:none;padding:12px;border-radius:8px;font-family:Consolas,monospace;font-size:15px;font-weight:bold;cursor:pointer;transition:.25s}
.btn-login:hover{box-shadow:0 4px 16px rgba(196,155,74,.4)}.btn-login:disabled{opacity:.5}
.login-ft{text-align:center;margin-top:16px;color:#555;font-size:12px}
</style>