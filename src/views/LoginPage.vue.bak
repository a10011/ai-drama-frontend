<template>
  <div class="auth-page">
    <div class="auth-card">
      <!-- 头部 -->
      <div class="auth-header">
        <div class="auth-logo">🎬</div>
        <h1>欢迎回来</h1>
        <p>登录你的短剧创作账号</p>
      </div>

      <!-- 注册成功提示 -->
      <div class="auth-success" v-if="$route.query.registered">✅ 注册成功，请登录</div>

      <!-- 表单 -->
      <div class="auth-form">
        <div class="field">
          <label>用户名</label>
          <input v-model="username" placeholder="请输入用户名" autocomplete="username" @input="clearError" @keyup.enter="focusPw" />
        </div>
        <div class="field">
          <label>密码</label>
          <div class="pw-wrap">
            <input ref="pwInput" v-model="password" :type="showPw?'text':'password'" placeholder="请输入密码" autocomplete="current-password" @keyup.enter="login" />
            <span class="pw-toggle" @click="showPw=!showPw">{{ showPw?'🙈':'👁️' }}</span>
          </div>
        </div>


        <!-- 错误提示 -->
        <div class="auth-error" v-if="error">{{ error }}</div>

        <!-- 提交 -->
        <button class="btn-gold" @click="login" :disabled="loading">
          {{ loading ? '登录中...' : '登 录' }}
        </button>

        <!-- 底部链接 -->
        <p class="auth-foot">没有账号？<router-link to="/register">立即注册</router-link></p>
      </div>
    </div>
  </div>
</template>

<script>
export default {
  data(){
    return{
      username:'',password:'',showPw:false,
      loading:false,error:''
    }
  },
  methods:{
    clearError(){this.error=''},
    focusPw(){this.$refs.pwInput?.focus()},

    async login(){
      this.error=''
      if(!this.username.trim()){this.error='请输入用户名';return}
      if(!this.password){this.error='请输入密码';return}
      this.loading=true
      try{
        const r=await(await fetch('/api/login',{
          method:'POST',headers:{'Content-Type':'application/json'},
          body:JSON.stringify({
            username:this.username.trim(),password:this.password
          })
        })).json()
        if(r.success&&r.data?.access_token){
          localStorage.setItem('token',r.data.access_token)
          this.$router.push('/create')
        }else{
          this.error=r.detail||r.error||'登录失败'
        }
      }catch(e){this.error='网络错误，请重试'}
      finally{this.loading=false}
    }
  },
}
</script>

<style scoped>
/* ===== 与注册页共享相同风格 ===== */
.auth-page{
  min-height:100vh;display:flex;align-items:center;justify-content:center;
  padding:24px;
  background:
    radial-gradient(ellipse at 20% 50%, rgba(196,155,74,0.04) 0%, transparent 50%),
    radial-gradient(ellipse at 80% 20%, rgba(196,155,74,0.03) 0%, transparent 50%),
    #0a0a0a;
}

.auth-card{
  width:100%;max-width:420px;
  background:#171717;border:1px solid #222;border-radius:16px;
  padding:40px 36px 32px;
  box-shadow:0 8px 32px rgba(0,0,0,0.4);
}

.auth-header{text-align:center;margin-bottom:28px}
.auth-logo{font-size:40px;margin-bottom:8px}
.auth-header h1{font-size:22px;font-weight:700;color:#e8e4dc;margin-bottom:4px}
.auth-header p{font-size:13px;color:#666}

.auth-success{
  text-align:center;font-size:13px;color:#4ade80;
  background:rgba(74,222,128,0.08);border:1px solid rgba(74,222,128,0.15);
  padding:10px 14px;border-radius:8px;margin-bottom:20px;
}

.auth-form{display:flex;flex-direction:column;gap:16px}
.field{display:flex;flex-direction:column;gap:6px}
.field label{font-size:13px;font-weight:500;color:#888}

.field input{
  width:100%;padding:11px 14px;
  background:#0a0a0a;border:1px solid #222;border-radius:8px;
  font-size:14px;color:#e8e4dc;outline:none;
  transition:border-color .2s,box-shadow .2s;
}
.field input::placeholder{color:#444}
.field input:focus{border-color:#c49b4a;box-shadow:0 0 0 3px rgba(196,155,74,0.08)}

.pw-wrap{position:relative}
.pw-wrap input{padding-right:42px}
.pw-toggle{
  position:absolute;right:12px;top:50%;transform:translateY(-50%);
  cursor:pointer;font-size:16px;user-select:none;opacity:.7;
}
.pw-toggle:hover{opacity:1}


.auth-error{
  background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.2);
  color:#ef4444;font-size:13px;padding:10px 14px;border-radius:8px;
}

.btn-gold{
  width:100%;padding:12px;
  background:linear-gradient(135deg,#c49b4a,#9a7b2e);
  color:#0a0a0a;border:none;border-radius:10px;
  font-size:15px;font-weight:700;cursor:pointer;
  transition:all .2s;margin-top:4px;
}
.btn-gold:hover{background:linear-gradient(135deg,#d4af6a,#b8963a);transform:translateY(-1px);box-shadow:0 4px 16px rgba(196,155,74,0.3)}
.btn-gold:active{transform:translateY(0)}
.btn-gold:disabled{opacity:.5;cursor:not-allowed;transform:none;box-shadow:none}

.auth-foot{text-align:center;font-size:13px;color:#555;margin-top:4px}
.auth-foot a{color:#c49b4a;text-decoration:none;font-weight:500}
.auth-foot a:hover{text-decoration:underline}
</style>
