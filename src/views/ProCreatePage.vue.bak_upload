  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: var(--bg-input);
}

.shot-img-wrapper {
  width: 100%;
  height: 100%;
}

.shot-img-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.shot-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  color: var(--text-muted);
}

.shot-info {
  padding: 12px 14px;
}

.shot-desc {
  font-size: 12px;
  color: var(--text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 6px;
}

.shot-meta {
  display: flex;
  gap: 6px;
}

.meta-tag {
  padding: 2px 8px;
  font-size: 10px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 10px;
  color: var(--text-muted);
}

.shot-actions {
  position: absolute;
  top: 8px;
  right: 8px;
  z-index: 2;
}

.btn-scene-gen {
  width: 32px;
  height: 32px;
  display: flex;
