<template>
  <div class="pro-create-page">
    <!-- 左侧导航步骤条 -->
    <aside class="sidebar">
      <div class="sidebar-header">
        <span class="sidebar-icon">📋</span>
        <h2 class="sidebar-title">专业共创模式</h2>
        <p class="sidebar-subtitle">步步为营，每一帧皆可精调</p>
      </div>

      <div class="steps-nav">
        <div
          v-for="(step, idx) in steps"
          :key="step.key"
          class="step-item"
          :class="{
            'step-active': currentStep === idx + 1,
            'step-done': step.done,
            'step-disabled': !step.done && currentStep !== idx + 1
          }"
          @click="navigateToStep(idx + 1)"
        >
          <div class="step-indicator">
            <span v-if="step.done" class="step-check">✅</span>
            <span v-else class="step-num">{{ idx + 1 }}</span>
          </div>
          <div class="step-info">
            <span class="step-label">{{ step.label }}</span>
            <span class="step-desc">{{ step.desc }}</span>
          </div>
        </div>
      </div>

      <!-- 整体进度 -->
      <div class="sidebar-progress">
        <div class="progress-header">
          <span class="progress-title">整体进度</span>
          <span class="progress-pct">{{ overallPercent }}%</span>
        </div>
        <div class="progress-track">
          <div class="progress-fill" :style="{ width: overallPercent + '%' }"></div>
        </div>
      </div>
    </aside>

    <!-- 右侧内容区 -->
    <main class="content-area">
      <!-- ═══ Step 1: 剧本编辑 ═══ -->
      <div v-if="currentStep === 1" class="step-panel fade-in">
        <div class="panel-header">
          <h3 class="panel-title">📝 剧本编辑</h3>
          <p class="panel-sub">输入创意或粘贴故事，AI 帮你打磨</p>
        </div>

        <div class="script-section">
          <textarea
            v-model="scriptText"
            class="script-textarea"
            placeholder="输入剧本创意或粘贴你的故事..."
            rows="10"
            maxlength="5000"
          ></textarea>

          <div class="script-actions">
            <button
              class="btn btn-ai"
              :disabled="!scriptText.trim() || aiBusy"
              @click="triggerAIScript"
            >
              <span v-if="aiBusy" class="spinner"></span>
              <span v-else>🎬</span>
              AI辅助创作
            </button>
            <button
              class="btn btn-manual"
              @click="isManualMode = true"
            >
              📝 手动编写
            </button>
          </div>

          <div class="save-row">
            <button
              class="btn btn-save"
              :disabled="!scriptText.trim() || savingScript"
              @click="saveScript"
            >
              <span v-if="savingScript" class="spinner"></span>
              <span v-else>💾</span>
              保存并下一步
            </button>
          </div>
        </div>
      </div>

      <!-- ═══ Step 2: 角色设计 ═══ -->
      <div v-if="currentStep === 2" class="step-panel fade-in">
        <div class="panel-header">
          <h3 class="panel-title">🎭 角色设计</h3>
          <p class="panel-sub">AI 自动提取角色，编辑属性一键生成肖像</p>
        </div>

        <!-- 剧本摘要 -->
        <div class="script-summary" v-if="scriptText">
          <span class="summary-label">剧本摘要</span>
          <p class="summary-text">{{ scriptText.slice(0, 120) }}{{ scriptText.length > 120 ? '...' : '' }}</p>
        </div>

        <!-- 角色提取 -->
        <div class="extract-row" v-if="!characters.length">
          <button
            class="btn btn-ai"
            :disabled="extracting"
            @click="extractCharacters"
          >
            <span v-if="extracting" class="spinner"></span>
            <span v-else>🎭</span>
            AI 提取角色
          </button>
        </div>

        <!-- 角色卡片网格 -->
        <div v-if="characters.length" class="char-grid">
          <div
            v-for="(char, cIdx) in characters"
            :key="cIdx"
            class="char-card"
          >
            <!-- 肖像预览 -->
            <div class="char-avatar-wrapper">
              <div v-if="char.portrait_url" class="char-portrait">
                <img :src="char.portrait_url" :alt="char.name" loading="lazy" />
              </div>
              <div v-else class="char-portrait placeholder-portrait">
                <span>{{ char.name ? char.name[0] : '?' }}</span>
              </div>
              <button
                class="btn-portrait"
                :disabled="generatingPortrait === cIdx"
                @click="generatePortrait(cIdx)"
              >
                <span v-if="generatingPortrait === cIdx" class="spinner-sm"></span>
                <span v-else>🎨</span>
                肖像
              </button>
            </div>

            <!-- 可编辑属性 -->
            <div class="char-fields">
              <div class="char-field">
                <label>姓名</label>
                <input v-model="char.name" placeholder="角色名" />
              </div>
              <div class="char-field">
                <label>性别</label>
                <select v-model="char.gender">
                  <option value="男">男</option>
                  <option value="女">女</option>
                  <option value="其他">其他</option>
                </select>
              </div>
              <div class="char-field">
                <label>性格</label>
                <textarea v-model="char.personality" placeholder="性格描述" rows="2"></textarea>
              </div>
              <div class="char-field">
                <label>外貌</label>
                <textarea v-model="char.appearance" placeholder="外貌描述" rows="2"></textarea>
              </div>
            </div>

            <div class="char-actions">
              <button class="btn-char-del" @click="removeCharacter(cIdx)">🗑️ 删除</button>
            </div>
          </div>

          <!-- 添加角色 -->
          <div class="char-card char-add-card" @click="addCharacter">
            <span class="add-icon">+</span>
            <span>添加角色</span>
          </div>
        </div>

        <div class="step-actions" v-if="characters.length">
          <button
            class="btn btn-save"
            :disabled="savingChars"
            @click="saveCharacters"
          >
            <span v-if="savingChars" class="spinner"></span>
            <span v-else>💾</span>
            保存并下一步
          </button>
        </div>
      </div>

      <!-- ═══ Step 3: 分镜规划 ═══ -->
      <div v-if="currentStep === 3" class="step-panel fade-in">
        <div class="panel-header">
          <h3 class="panel-title">📋 分镜规划</h3>
          <p class="panel-sub">AI 生成分镜列表，拖拽排序，批量生成场景图</p>
        </div>

        <div class="shot-toolbar" v-if="!shots.length">
          <button
            class="btn btn-ai"
            :disabled="generatingShots"
            @click="generateShots"
          >
            <span v-if="generatingShots" class="spinner"></span>
            <span v-else>📋</span>
            AI 生成分镜
          </button>
        </div>

        <!-- 分镜网格 -->
        <div v-if="shots.length" class="shot-grid" ref="shotGrid">
          <div
            v-for="(shot, sIdx) in shots"
            :key="shot.id || sIdx"
            class="shot-card"
            draggable="true"
            @dragstart="onDragStart($event, sIdx)"
            @dragover.prevent="onDragOver($event, sIdx)"
            @drop="onDrop($event, sIdx)"
          >
            <div class="shot-order">{{ sIdx + 1 }}</div>
            <div class="shot-thumb">
              <div v-if="shot.scene_image_url" class="shot-img-wrapper">
                <img :src="shot.scene_image_url" :alt="'分镜' + (sIdx+1)" loading="lazy" />
              </div>
              <div v-else class="shot-img-placeholder">
                <span>🎬</span>
              </div>
            </div>
            <div class="shot-info">
              <p class="shot-desc">{{ shot.description || shot.content || '--' }}</p>
              <div class="shot-meta">
                <span class="meta-tag">{{ shot.camera || '中景' }}</span>
                <span class="meta-tag">{{ shot.duration || '3s' }}</span>
              </div>
            </div>
            <div class="shot-actions">
              <button class="btn-scene-gen" :disabled="genSceneIdx === sIdx" @click.stop="generateSceneImage(sIdx)">
                <span v-if="genSceneIdx === sIdx" class="spinner-sm"></span>
                <span v-else>🖼️</span>
              </button>
            </div>
          </div>
        </div>

        <div class="step-actions" v-if="shots.length">
          <button
            class="btn btn-ai"
            :disabled="batchGeneratingScenes"
            @click="batchGenerateScenes"
          >
            <span v-if="batchGeneratingScenes" class="spinner"></span>
            <span v-else>🖼️</span>
            批量生成场景图
          </button>
          <button
            class="btn btn-save"
            :disabled="savingShots"
            @click="saveShots"
          >
            <span v-if="savingShots" class="spinner"></span>
            <span v-else>💾</span>
            保存并下一步
          </button>
        </div>
      </div>

      <!-- ═══ Step 4: 视频生成 ═══ -->
      <div v-if="currentStep === 4" class="step-panel fade-in">
        <div class="panel-header">
          <h3 class="panel-title">🎬 视频生成</h3>
          <p class="panel-sub">逐个分镜生成 AI 视频</p>
        </div>

        <div class="video-shot-list">
          <div
            v-for="(shot, sIdx) in shots"
            :key="shot.id || sIdx"
            class="video-shot-item"
            :class="'vs-' + (shot.videoStatus || 'pending')"
          >
            <div class="vs-order">{{ sIdx + 1 }}</div>
            <div class="vs-thumb">
              <div v-if="shot.scene_image_url" class="vs-img-wrapper">
                <img :src="shot.scene_image_url" :alt="'分镜'+(sIdx+1)" loading="lazy" />
              </div>
              <div v-else class="vs-img-placeholder">🎬</div>
            </div>
            <div class="vs-info">
              <p class="vs-desc">{{ shot.description || shot.content || '--' }}</p>
            </div>
            <div class="vs-status">
              <template v-if="shot.videoStatus === 'completed'">
                <span class="status-icon">✅</span>
                <span class="status-label">完成</span>
              </template>
              <template v-else-if="shot.videoStatus === 'generating'">
                <span class="spinner-sm"></span>
                <span class="status-label">生成中</span>
              </template>
              <template v-else-if="shot.videoStatus === 'failed'">
                <span class="status-icon">❌</span>
                <span class="status-label">失败</span>
              </template>
              <template v-else>
                <span class="status-icon">⏳</span>
                <span class="status-label">等待中</span>
              </template>
            </div>
            <div class="vs-action">
              <button
                class="btn-video-gen"
                :disabled="shot.videoStatus === 'generating' || generatingVideoIdx === sIdx"
                @click="generateVideo(sIdx)"
              >
                <span v-if="generatingVideoIdx === sIdx" class="spinner-sm"></span>
                <span v-else-if="shot.video_url">🔁</span>
                <span v-else>🎬</span>
                {{ shot.video_url ? '重新生成' : '生成' }}
              </button>
            </div>
            <div v-if="shot.video_url" class="vs-preview" @click="previewVideo(shot.video_url)">
              <video :src="shot.video_url" muted preload="metadata"></video>
              <span class="play-overlay">▶</span>
            </div>
          </div>
        </div>

        <div class="step-actions">
          <button
            class="btn btn-save"
            :disabled="hasPendingVideos"
            @click="goToStep5"
          >
            🎬 全部完成，下一步
          </button>
        </div>
      </div>

      <!-- ═══ Step 5: 合成发布 ═══ -->
      <div v-if="currentStep === 5" class="step-panel fade-in">
        <div class="panel-header">
          <h3 class="panel-title">📦 合成发布</h3>
          <p class="panel-sub">合并所有分镜视频，导出最终作品</p>
        </div>

        <!-- 分镜视频预览列表 -->
        <div class="final-shot-list">
          <div
            v-for="(shot, sIdx) in shots"
            :key="shot.id || sIdx"
            class="final-shot-item"
            :class="{ 'has-video': !!shot.video_url }"
          >
            <div class="fs-order">{{ sIdx + 1 }}</div>
            <div class="fs-thumb" @click="previewVideo(shot.video_url)" v-if="shot.video_url">
              <video :src="shot.video_url" muted preload="metadata"></video>
              <span class="play-overlay">▶</span>
            </div>
            <div class="fs-thumb fs-thumb-placeholder" v-else>
              <span>❌</span>
            </div>
            <div class="fs-info">
              <p class="fs-desc">{{ shot.description || shot.content || '--' }}</p>
            </div>
          </div>
        </div>

        <!-- 合成区域 -->
        <div class="composite-section">
          <button
            class="btn btn-save btn-composite"
            :disabled="isCompositing || !allVideosReady"
            @click="startComposite"
          >
            <span v-if="isCompositing" class="spinner"></span>
            <span v-else>🔗</span>
            {{ isCompositing ? '合成中...' : '合并视频' }}
          </button>

          <!-- 合成进度条 -->
          <div v-if="isCompositing" class="composite-progress">
            <div class="cp-bar">
              <div class="cp-fill" :style="{ width: compositeProgress + '%' }"></div>
            </div>
            <span class="cp-pct">{{ compositeProgress }}%</span>
          </div>
        </div>

        <!-- 最终视频播放器 -->
        <div v-if="finalVideoUrl" class="final-video-section fade-in">
          <h4 class="final-video-title">✨ 最终作品</h4>
          <div class="final-video-wrapper">
            <video
              :src="finalVideoUrl"
              controls
              playsinline
              preload="metadata"
              class="final-video-player"
            ></video>
          </div>

          <div class="final-actions">
            <button class="btn btn-ai" @click="downloadFinalVideo">📥 下载</button>
            <button class="btn btn-manual" @click="shareFinalVideo">📱 分享</button>
            <button class="btn btn-manual" @click="resetAll">🔄 重新生成</button>
          </div>
        </div>
      </div>
    </main>

    <!-- 视频预览弹窗 -->
    <div v-if="videoPreviewUrl" class="modal-overlay" @click.self="videoPreviewUrl = ''">
      <div class="modal-card video-modal">
        <div class="modal-header">
          <h3>🎬 视频预览</h3>
          <button class="modal-close" @click="videoPreviewUrl = ''">✕</button>
        </div>
        <div class="modal-body">
          <video
            :src="videoPreviewUrl"
            controls
            playsinline
            preload="auto"
            class="preview-video"
            autoplay
          ></video>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
const API = '/api/v1'

async function apiReq(method, path, body) {
  const token = localStorage.getItem('token')
  const opts = { method, headers: { 'Content-Type': 'application/json' } }
  if (token) opts.headers['Authorization'] = 'Bearer ' + token
  if (body) opts.body = JSON.stringify(body)
  const r = await fetch(API + path, opts)
  return r.json()
}

export default {
  name: 'ProCreatePage',
  data() {
    return {
      currentStep: 1,
      steps: [
        { key: 'script', label: '剧本编辑', desc: '创作打磨剧本', done: false },
        { key: 'character', label: '角色设计', desc: '角色提取与肖像', done: false },
        { key: 'shot', label: '分镜规划', desc: '分镜排序与场景图', done: false },
        { key: 'video', label: '视频生成', desc: 'AI 逐镜生成', done: false },
        { key: 'composite', label: '合成发布', desc: '合并导出作品', done: false },
      ],

      // Step 1
      scriptText: '',
      aiBusy: false,
      savingScript: false,
      isManualMode: false,
      projectId: null,

      // Step 2
      characters: [],
      extracting: false,
      savingChars: false,
      generatingPortrait: null,

      // Step 3
      shots: [],
      generatingShots: false,
      savingShots: false,
      genSceneIdx: null,
      batchGeneratingScenes: false,
      dragIndex: null,

      // Step 4
      generatingVideoIdx: null,

      // Step 5
      isCompositing: false,
      compositeProgress: 0,
      finalVideoUrl: '',
      compositePollTimer: null,

      // 通用
      videoPreviewUrl: '',
      token: '',
    }
  },
  computed: {
    overallPercent() {
      const done = this.steps.filter(s => s.done).length
      return Math.round((done / this.steps.length) * 100)
    },
    hasPendingVideos() {
      return this.shots.some(s => !s.video_url || s.videoStatus === 'pending' || s.videoStatus === 'failed')
    },
    allVideosReady() {
      return this.shots.length > 0 && this.shots.every(s => !!s.video_url && s.videoStatus === 'completed')
    },
  },
  mounted() {
    this.token = localStorage.getItem('token') || ''
    // 恢复已保存的项目
    const savedProjectId = localStorage.getItem('pro_project_id')
    if (savedProjectId) {
      this.projectId = savedProjectId
      this.loadProject(savedProjectId)
    }
  },
  beforeUnmount() {
    this.stopCompositePolling()
  },
  methods: {
    navigateToStep(step) {
      // 只允许跳转到已完成或当前步骤
      if (step === this.currentStep) return
      if (this.steps[step - 1] && this.steps[step - 1].done) {
        this.currentStep = step
      }
    },

    // ═══ Step 1: 剧本编辑 ═══
    async triggerAIScript() {
      if (!this.scriptText.trim()) return
      this.aiBusy = true
      try {
        const res = await apiReq('POST', '/script/generate', {
          prompt: this.scriptText,
        })
        if (res.success && res.data) {
          this.scriptText = res.data.script_text || res.data.content || res.data || this.scriptText
        } else {
          alert('AI 辅助失败: ' + (res.message || '请重试'))
        }
      } catch (e) {
        console.error('AI script failed:', e)
        alert('AI 辅助失败: 网络错误')
      }
      this.aiBusy = false
    },

    async saveScript() {
      if (!this.scriptText.trim()) return
      this.savingScript = true
      try {
        const body = {
          script_text: this.scriptText,
          title: this.scriptText.slice(0, 50),
        }
        if (this.projectId) body.project_id = this.projectId

        const res = await apiReq('POST', '/projects/create', body)
        if (res.success) {
          this.projectId = res.project_id || res.id
          localStorage.setItem('pro_project_id', this.projectId)
          this.steps[0].done = true
          this.currentStep = 2
        } else {
          const errMsg = res.error || res.message || '余额不足，请先充值'
          alert('保存失败: ' + errMsg)
        }
      } catch (e) {
        console.error('save script failed:', e)
        alert('保存失败: 网络错误')
      }
      this.savingScript = false
    },

    // ═══ Step 2: 角色设计 ═══
    async extractCharacters() {
      if (!this.projectId) {
        alert('请先保存剧本')
        return
      }
      this.extracting = true
      try {
        const res = await apiReq('POST', '/characters/extract', {
          project_id: this.projectId,
          script_text: this.scriptText,
        })
        if (res.success && res.data) {
          const list = res.data.characters || res.data || []
          this.characters = list.map(c => ({
            name: c.name || '',
            gender: c.gender || '男',
            personality: c.personality || c.description || '',
            appearance: c.appearance || '',
            portrait_url: c.portrait_url || '',
          }))
        } else {
          alert('角色提取失败: ' + (res.message || '请重试'))
        }
      } catch (e) {
        console.error('extract characters failed:', e)
        alert('角色提取失败: 网络错误')
      }
      this.extracting = false
    },

    addCharacter() {
      this.characters.push({
        name: '',
        gender: '男',
        personality: '',
        appearance: '',
        portrait_url: '',
      })
    },

    removeCharacter(idx) {
      this.characters.splice(idx, 1)
    },

    async generatePortrait(idx) {
      const char = this.characters[idx]
      if (!char.name || !char.appearance) {
        alert('请先填写姓名和外貌描述')
        return
      }
      this.generatingPortrait = idx
      try {
        const res = await apiReq('POST', '/characters/portrait', {
          name: char.name,
          gender: char.gender,
          personality: char.personality,
          appearance: char.appearance,
          project_id: this.projectId,
        })
        if (res.success && res.data) {
          char.portrait_url = res.data.portrait_url || res.data.image_url || res.data.url || ''
          // 尝试响应式更新
          this.characters = [...this.characters]
        } else {
          alert('肖像生成失败: ' + (res.message || '请重试'))
        }
      } catch (e) {
        console.error('portrait generation failed:', e)
        alert('肖像生成失败: 网络错误')
      }
      this.generatingPortrait = null
    },

    async saveCharacters() {
      this.savingChars = true
      try {
        const res = await apiReq('POST', '/characters/save', {
          project_id: this.projectId,
          characters: this.characters,
        })
        if (res.success) {
          this.steps[1].done = true
          this.currentStep = 3
        } else {
          alert('保存角色失败: ' + (res.message || '请重试'))
        }
      } catch (e) {
        console.error('save characters failed:', e)
        alert('保存角色失败: 网络错误')
      }
      this.savingChars = false
    },

    // ═══ Step 3: 分镜规划 ═══
    async generateShots() {
      if (!this.projectId) {
        alert('请先保存剧本')
        return
      }
      this.generatingShots = true
      try {
        const res = await apiReq('POST', '/shot/list', {
          project_id: this.projectId,
          script_text: this.scriptText,
          characters: this.characters,
        })
        if (res.success && res.data) {
          const list = res.data.shots || res.data || []
          this.shots = list.map(s => ({
            id: s.id || s.shot_id || '',
            description: s.description || s.content || '',
            camera: s.camera || '中景',
            duration: s.duration || '3s',
            scene_image_url: s.scene_image_url || '',
            video_url: s.video_url || '',
            videoStatus: s.videoStatus || 'pending',
          }))
        } else {
          alert('分镜生成失败: ' + (res.message || '请重试'))
        }
      } catch (e) {
        console.error('generate shots failed:', e)
        alert('分镜生成失败: 网络错误')
      }
      this.generatingShots = false
    },

    // 拖拽排序
    onDragStart(e, idx) {
      this.dragIndex = idx
      e.dataTransfer.effectAllowed = 'move'
    },
    onDragOver(e, idx) {
      e.dataTransfer.dropEffect = 'move'
    },
    onDrop(e, idx) {
      if (this.dragIndex === null || this.dragIndex === idx) return
      const item = this.shots.splice(this.dragIndex, 1)[0]
      this.shots.splice(idx, 0, item)
      this.dragIndex = null
    },

    async generateSceneImage(sIdx) {
      const shot = this.shots[sIdx]
      this.genSceneIdx = sIdx
      try {
        const res = await apiReq('POST', '/shot/scene-image', {
          shot_id: shot.id || sIdx + 1,
          project_id: this.projectId,
          description: shot.description,
        })
        if (res.success && res.data) {
          shot.scene_image_url = res.data.scene_image_url || res.data.image_url || ''
          this.shots = [...this.shots]
        } else {
          alert('场景图生成失败: ' + (res.message || '请重试'))
        }
      } catch (e) {
        console.error('scene image failed:', e)
        alert('场景图生成失败: 网络错误')
      }
      this.genSceneIdx = null
    },

    async batchGenerateScenes() {
      this.batchGeneratingScenes = true
      for (let i = 0; i < this.shots.length; i++) {
        if (this.shots[i].scene_image_url) continue
        this.genSceneIdx = i
        try {
          const res = await apiReq('POST', '/shot/scene-image', {
            shot_id: this.shots[i].id || i + 1,
            project_id: this.projectId,
            description: this.shots[i].description,
          })
          if (res.success && res.data) {
            this.shots[i].scene_image_url = res.data.scene_image_url || res.data.image_url || ''
            this.shots = [...this.shots]
          }
        } catch (e) {
          console.warn('batch scene image failed for shot', i, e)
        }
        // 每张之间稍等
        await new Promise(r => setTimeout(r, 300))
      }
      this.genSceneIdx = null
      this.batchGeneratingScenes = false
    },

    async saveShots() {
      this.savingShots = true
      try {
        const res = await apiReq('POST', '/shot/save', {
          project_id: this.projectId,
          shots: this.shots,
        })
        if (res.success) {
          this.steps[2].done = true
          this.currentStep = 4
        } else {
          alert('保存分镜失败: ' + (res.message || '请重试'))
        }
      } catch (e) {
        console.error('save shots failed:', e)
        alert('保存分镜失败: 网络错误')
      }
      this.savingShots = false
    },

    // ═══ Step 4: 视频生成 ═══
    async generateVideo(sIdx) {
      const shot = this.shots[sIdx]
      this.generatingVideoIdx = sIdx
      shot.videoStatus = 'generating'
      try {
        const res = await apiReq('POST', '/video/generate', {
          shot_id: shot.id || sIdx + 1,
          project_id: this.projectId,
          scene_image_url: shot.scene_image_url,
          description: shot.description,
        })
        if (res.success && res.data) {
          shot.video_url = res.data.video_url || res.data.url || ''
          shot.videoStatus = 'completed'
        } else {
          shot.videoStatus = 'failed'
          alert('视频生成失败: ' + (res.message || '请重试'))
        }
      } catch (e) {
        console.error('video generation failed:', e)
        shot.videoStatus = 'failed'
        alert('视频生成失败: 网络错误')
      }
      this.generatingVideoIdx = null
      this.shots = [...this.shots]
    },

    goToStep5() {
      this.steps[3].done = true
      this.currentStep = 5
    },

    // ═══ Step 5: 合成发布 ═══
    async startComposite() {
      this.isCompositing = true
      this.compositeProgress = 0
      try {
        const res = await apiReq('POST', '/video/composite', {
          project_id: this.projectId,
          shot_videos: this.shots.map(s => ({
            url: s.video_url,
            description: s.description,
          })),
        })
        if (res.success && res.data) {
          const taskId = res.data.task_id || res.data.composite_id
          this.startCompositePolling(taskId)
        } else {
          alert('合成启动失败: ' + (res.message || '请重试'))
          this.isCompositing = false
        }
      } catch (e) {
        console.error('composite start failed:', e)
        alert('合成启动失败: 网络错误')
        this.isCompositing = false
      }
    },

    startCompositePolling(taskId) {
      this.stopCompositePolling()
      this.compositePollTimer = setInterval(async () => {
        try {
          const res = await apiReq('GET', '/video/composite/progress/' + taskId)
          if (res.success && res.data) {
            this.compositeProgress = res.data.progress || res.data.percent || 0
            if (res.data.finished || res.data.status === 'completed') {
              this.finalVideoUrl = res.data.video_url || res.data.url || ''
              this.isCompositing = false
              this.stopCompositePolling()
            }
            if (res.data.status === 'failed') {
              alert('合成失败: ' + (res.data.error || '请重试'))
              this.isCompositing = false
              this.stopCompositePolling()
            }
          }
          if (this.compositeProgress >= 100) {
            // 保险：刷新一次获取最终 url
            const r2 = await apiReq('GET', '/video/composite/progress/' + taskId)
            if (r2.success && r2.data && r2.data.video_url) {
              this.finalVideoUrl = r2.data.video_url
            }
            this.isCompositing = false
            this.stopCompositePolling()
          }
        } catch (e) {
          console.warn('composite poll failed:', e)
        }
      }, 2000)
    },

    stopCompositePolling() {
      if (this.compositePollTimer) {
        clearInterval(this.compositePollTimer)
        this.compositePollTimer = null
      }
    },

    downloadFinalVideo() {
      if (this.finalVideoUrl) {
        const a = document.createElement('a')
        a.href = this.finalVideoUrl
        a.download = ''
        document.body.appendChild(a)
        a.click()
        document.body.removeChild(a)
      }
    },

    shareFinalVideo() {
      if (navigator.share && this.finalVideoUrl) {
        navigator.share({ title: '智剧AI - 短剧作品', url: this.finalVideoUrl }).catch(() => {})
      } else if (navigator.clipboard) {
        navigator.clipboard.writeText(this.finalVideoUrl || window.location.href)
          .then(() => alert('链接已复制到剪贴板'))
          .catch(() => {
            const input = document.createElement('input')
            input.value = this.finalVideoUrl
            document.body.appendChild(input)
            input.select()
            document.execCommand('copy')
            document.body.removeChild(input)
            alert('链接已复制到剪贴板')
          })
      }
    },

    resetAll() {
      this.stopCompositePolling()
      this.finalVideoUrl = ''
      this.compositeProgress = 0
      this.currentStep = 4
      this.steps[3].done = false
      this.steps[4].done = false
    },

    previewVideo(url) {
      if (url) this.videoPreviewUrl = url
    },

    // 恢复项目
    async loadProject(id) {
      try {
        const res = await apiReq('GET', '/projects/' + id)
        if (res.success && res.data) {
          const data = res.data
          if (data.script_text) this.scriptText = data.script_text
          if (data.characters && data.characters.length) this.characters = data.characters
          if (data.shots && data.shots.length) this.shots = data.shots
          // 恢复步骤状态
          this.steps[0].done = true
          if (this.characters.length) this.steps[1].done = true
          if (this.shots.length) this.steps[2].done = true
          if (this.shots.some(s => s.video_url)) this.steps[3].done = true
          if (data.final_video_url) {
            this.finalVideoUrl = data.final_video_url
            this.steps[4].done = true
          }
        }
      } catch (e) {
        console.warn('load project failed:', e)
      }
    },
  },
}
</script>

<style scoped>
/* ═══════════════════════════════════════════
   专业共创模式 - ProCreatePage
   ═══════════════════════════════════════════ */

