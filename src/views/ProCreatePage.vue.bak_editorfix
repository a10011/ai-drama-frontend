              if (found.status === 'failed') {
                console.error(stage + '生成失败: ' + (found.error || ''))
                return null
              }
              // running：继续轮询，不打断
            }
          }
        } catch (e) {}
      }
      // 超时不弹阻塞式 alert，仅控制台提示；后端仍在跑，用户刷新可继续看结果
