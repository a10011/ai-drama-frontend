  font-size: 12px;
  color: var(--text-muted);
}

.steps-nav {
  flex: 1;
}

.step-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  border-radius: 10px;
  cursor: pointer;
  transition: all 0.25s ease;
  margin-bottom: 4px;
}

.step-item:hover:not(.step-disabled) {
  background: rgba(138, 43, 226, 0.06);
}

.step-item.step-active {
  background: rgba(138, 43, 226, 0.12);
  border: 1px solid rgba(138, 43, 226, 0.25);
}

.step-item.step-done {
  cursor: pointer;
}

.step-item.step-disabled {
  cursor: not-allowed;
  opacity: 0.5;
}

.step-indicator {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 700;
  flex-shrink: 0;
  background: var(--bg-input);
  border: 2px solid var(--border);
  color: var(--text-muted);
  transition: all 0.25s ease;
}

.step-active .step-indicator {
  background: #8A2BE2;
  border-color: #8A2BE2;
  color: #fff;
  box-shadow: 0 0 12px rgba(138, 43, 226, 0.4);
}

.step-done .step-indicator {
  background: rgba(0, 230, 118, 0.15);
  border-color: var(--success);
}

.step-check {
  font-size: 16px;
}

.step-num {
  font-size: 14px;
  font-weight: 700;
}

.step-info {
  display: flex;
  flex-direction: column;
}

.step-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
}

.step-done .step-label {
  color: var(--success);
}

.step-desc {
  font-size: 11px;
  color: var(--text-muted);
  margin-top: 2px;
}

.step-active .step-desc {
  color: var(--text-secondary);
}

/* ─── 进度条 ─── */
.sidebar-progress {
  margin-top: 20px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.progress-title {
  font-size: 12px;
  color: var(--text-secondary);
}

.progress-pct {
  font-size: 13px;
  font-weight: 700;
  color: var(--highlight);
}

.progress-track {
  height: 6px;
  background: var(--bg-input);
  border-radius: 3px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #8A2BE2, #00FFFF);
  border-radius: 3px;
  transition: width 0.5s ease;
}

/* ─── 右侧内容区 ─── */
.content-area {
  flex: 1;
  min-width: 0;
}

.step-panel {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 36px;
}

.panel-header {
  margin-bottom: 28px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border);
}

.panel-title {
  font-size: 20px;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4px;
}

.panel-sub {
  font-size: 14px;
  color: var(--text-secondary);
}

/* ─── 通用按钮 ─── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 22px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition);
  border: none;
  white-space: nowrap;
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-ai {
  background: linear-gradient(135deg, #8A2BE2, #00FFFF);
  color: #fff;
}

.btn-ai:hover:not(:disabled) {
  box-shadow: 0 0 20px rgba(0, 255, 255, 0.25);
  transform: translateY(-1px);
}

.btn-manual {
  background: var(--bg-input);
  border: 1px solid var(--border);
  color: var(--text-primary);
}

.btn-manual:hover:not(:disabled) {
  border-color: var(--highlight);
  background: var(--bg-elevated, #2a2a3e);
}

.btn-save {
  background: linear-gradient(135deg, #8A2BE2, #00FFFF);
  color: #fff;
  font-size: 15px;
  padding: 12px 28px;
}

.btn-save:hover:not(:disabled) {
  box-shadow: 0 0 20px rgba(0, 255, 255, 0.25);
  transform: translateY(-1px);
}

/* ─── Spinner ─── */
.spinner {
  display: inline-block;
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

.spinner-sm {
  display: inline-block;
  width: 14px;
  height: 14px;
  border: 2px solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  vertical-align: middle;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ─── 动画 ─── */
.fade-in {
  animation: fadeIn 0.35s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ═══ Step 1: 剧本编辑 ═══ */
/* 模式切换 Tab */
.script-mode-tabs {
  display: flex; gap: 0; margin-bottom: 16px;
  border-bottom: 1px solid var(--border, #2D2D4E);
}
.mode-tab-btn {
  padding: 10px 24px; font-size: 14px; font-weight: 600;
  background: none; border: none; border-bottom: 2px solid transparent;
  color: var(--text-muted, #6C6C8A); cursor: pointer; transition: all 0.2s;
}
.mode-tab-btn:hover { color: var(--text-primary, #EDEDF5); }
.mode-tab-btn.active { color: var(--accent, #7C5CFC); border-bottom-color: var(--accent, #7C5CFC); }

/* 改编模式 textarea 更大 */
.script-textarea.adapt-mode {
  min-height: 420px; font-size: 15px; line-height: 1.9;
  font-family: 'Noto Sans SC', 'PingFang SC', sans-serif;
}

.script-section {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.script-textarea {
  width: 100%;
  min-height: 220px;
  padding: 18px 20px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-primary);
  font-size: 15px;
  font-family: 'Inter', 'Noto Sans SC', -apple-system, sans-serif;
  line-height: 1.7;
  resize: vertical;
  transition: all var(--transition);
}

.script-textarea:focus {
  border-color: #8A2BE2;
  box-shadow: 0 0 0 3px rgba(138, 43, 226, 0.15);
  outline: none;
}

.script-textarea::placeholder {
  color: var(--text-muted);
  font-size: 14px;
}

.script-actions {
  display: flex;
  gap: 10px;
}

.save-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 8px;
}

/* ═══ Step 2: 角色设计 ═══ */
.script-summary {
  padding: 12px 16px;
  background: rgba(0, 255, 255, 0.04);
  border: 1px solid rgba(0, 255, 255, 0.1);
  border-radius: var(--radius-sm);
  margin-bottom: 20px;
}

.summary-label {
  font-size: 11px;
  font-weight: 600;
  color: var(--highlight);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  display: block;
  margin-bottom: 4px;
}

.summary-text {
  font-size: 13px;
  color: var(--text-secondary);
  line-height: 1.5;
}

.extract-row {
  margin-bottom: 20px;
}

.char-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 16px;
  margin-bottom: 20px;
}

.char-card {
  background: #252536;
  border: 1px solid #333355;
  border-radius: 12px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: all var(--transition);
}

.char-card:hover {
  border-color: rgba(138, 43, 226, 0.3);
}

.char-avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.char-portrait {
  width: 100px;
  height: 100px;
  border-radius: 12px;
  overflow: hidden;
  background: var(--bg-input);
  border: 1px solid var(--border);
}

.char-portrait img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.placeholder-portrait {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  font-weight: 700;
  color: var(--text-muted);
}

.btn-portrait {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 6px 14px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 20px;
  color: var(--text-secondary);
  font-size: 12px;
  cursor: pointer;
  transition: all var(--transition);
}

.btn-portrait:hover:not(:disabled) {
  border-color: var(--highlight);
  color: var(--highlight);
}

.btn-upload {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 6px 14px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 20px;
  color: var(--text-secondary);
  font-size: 12px;
  cursor: pointer;
  transition: all var(--transition);
}

.btn-upload:hover {
  border-color: var(--success, #00e676);
  color: var(--success, #00e676);
}

.char-fields {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.char-field {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.char-field label {
  font-size: 11px;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.03em;
}

.char-field input,
.char-field select,
.char-field textarea {
  width: 100%;
  padding: 7px 10px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-primary);
  font-size: 13px;
  font-family: inherit;
  transition: all var(--transition);
}

.char-field input:focus,
.char-field select:focus,
.char-field textarea:focus {
  border-color: #8A2BE2;
  box-shadow: 0 0 0 2px rgba(138, 43, 226, 0.12);
  outline: none;
}

.char-field textarea {
  resize: vertical;
  min-height: 40px;
}

.char-actions {
  display: flex;
  justify-content: flex-end;
}

.btn-char-del {
  padding: 5px 12px;
  background: transparent;
  border: 1px solid transparent;
  border-radius: 6px;
  color: var(--danger);
  font-size: 12px;
  cursor: pointer;
  transition: all var(--transition);
}

.btn-char-del:hover {
  background: rgba(255, 82, 82, 0.1);
  border-color: rgba(255, 82, 82, 0.2);
}

.char-add-card {
  border: 2px dashed #333355;
  background: transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  min-height: 120px;
  color: var(--text-muted);
  font-size: 14px;
  transition: all var(--transition);
}

.char-add-card:hover {
  border-color: var(--highlight);
  color: var(--highlight);
  background: rgba(0, 255, 255, 0.03);
}

.add-icon {
  font-size: 32px;
  font-weight: 300;
  margin-bottom: 4px;
}

.step-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  margin-top: 8px;
}

/* ═══ Step 3: 分镜规划 ═══ */
.shot-toolbar {
  margin-bottom: 20px;
}

.shot-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 14px;
  margin-bottom: 20px;
}

.shot-card {
  background: #252536;
  border: 1px solid #333355;
  border-radius: 12px;
  overflow: hidden;
  cursor: grab;
  transition: all var(--transition);
  position: relative;
}

.shot-card:hover {
  border-color: rgba(138, 43, 226, 0.3);
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
}

.shot-card:active {
  cursor: grabbing;
}

.shot-order {
  position: absolute;
  top: 8px;
  left: 8px;
  width: 26px;
  height: 26px;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
  color: #fff;
  z-index: 2;
}

.shot-thumb {
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: var(--bg-input);
}

.shot-img-wrapper {
  width: 100%;
  height: 100%;
}

.shot-img-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.shot-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  color: var(--text-muted);
}

.shot-info {
  padding: 12px 14px;
}

.shot-scene-name {
  font-size: 12px;
  font-weight: 600;
  color: var(--accent-color, #667eea);
  margin-bottom: 3px;
}
.shot-desc {  font-size: 12px;
  color: var(--text-secondary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 4px;
}
.shot-dialogue {
  font-size: 12px;
  color: #d4a05a;
  font-style: italic;
  line-height: 1.4;
  margin-bottom: 6px;
  padding: 3px 6px;
  background: rgba(212, 160, 90, 0.1);
  border-radius: 4px;
}

.shot-meta {
  display: flex;
  gap: 6px;
}

.meta-tag {
  padding: 2px 8px;
  font-size: 10px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: 10px;
  color: var(--text-muted);
}

.shot-actions {
  position: absolute;
  top: 8px;
  right: 8px;
  z-index: 2;
}

.btn-scene-gen {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.6);
  border: none;
  border-radius: 8px;
  color: #fff;
  font-size: 14px;
  cursor: pointer;
  transition: all var(--transition);
}

.btn-scene-gen:hover:not(:disabled) {
  background: rgba(138, 43, 226, 0.8);
}

/* ═══ Step 4: 视频生成 ═══ */
.video-shot-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 20px;
}

.video-shot-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  background: #252536;
  border: 1px solid #333355;
  border-radius: 12px;
  transition: all var(--transition);
  position: relative;
}

.video-shot-item.vs-completed {
  border-color: rgba(0, 230, 118, 0.2);
  background: rgba(0, 230, 118, 0.03);
}

.video-shot-item.vs-failed {
  border-color: rgba(255, 82, 82, 0.2);
  background: rgba(255, 82, 82, 0.03);
}

.video-shot-item.vs-generating {
  border-color: rgba(138, 43, 226, 0.25);
  background: rgba(138, 43, 226, 0.05);
}

.vs-order {
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
  background: var(--bg-input);
  border-radius: 50%;
  flex-shrink: 0;
}

.vs-thumb {
  width: 60px;
  height: 40px;
  border-radius: 6px;
  overflow: hidden;
  flex-shrink: 0;
  background: var(--bg-input);
}

.vs-img-wrapper {
  width: 100%;
  height: 100%;
}

.vs-img-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.vs-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}

.vs-info {
  flex: 1;
  min-width: 0;
}

.vs-desc {
  font-size: 12px;
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.vs-status {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
  font-size: 12px;
  min-width: 60px;
}

.status-icon {
  font-size: 14px;
}

.status-label {
  color: var(--text-secondary);
}

.vs-completed .status-label {
  color: var(--success);
}

.vs-failed .status-label {
  color: var(--danger);
}

.vs-action {
  flex-shrink: 0;
}

.btn-video-gen {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 6px 14px;
  background: linear-gradient(135deg, #8A2BE2, #00FFFF);
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition);
}

.btn-video-gen:hover:not(:disabled) {
  box-shadow: 0 0 12px rgba(0, 255, 255, 0.2);
}

.btn-video-gen:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.vs-preview {
  position: absolute;
  top: 8px;
  right: 100px;
  width: 80px;
  height: 56px;
  border-radius: 6px;
  overflow: hidden;
  cursor: pointer;
  background: #000;
}

.vs-preview video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.play-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 28px;
  height: 28px;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: #fff;
}

/* ═══ Step 5: 合成发布 ═══ */
.final-shot-list {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  padding-bottom: 12px;
  margin-bottom: 24px;
}

.final-shot-item {
  flex-shrink: 0;
  width: 120px;
  background: #252536;
  border: 1px solid #333355;
  border-radius: 10px;
  overflow: hidden;
  transition: all var(--transition);
}

.final-shot-item.has-video {
  border-color: rgba(0, 230, 118, 0.2);
}

.fs-order {
  text-align: center;
  padding: 4px;
  font-size: 11px;
  font-weight: 700;
  color: var(--text-muted);
  background: var(--bg-input);
}

.fs-thumb {
  width: 100%;
  aspect-ratio: 16 / 9;
  position: relative;
  cursor: pointer;
  overflow: hidden;
  background: var(--bg-input);
}

.fs-thumb video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.fs-thumb-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: var(--text-muted);
}

.fs-info {
  padding: 6px 8px;
}

.fs-desc {
  font-size: 10px;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ─── 合成区 ─── */
.composite-section {
  text-align: center;
  padding: 20px;
  background: var(--bg-input);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  margin-bottom: 20px;
}

.btn-composite {
  font-size: 16px;
  padding: 14px 36px;
}

.composite-progress {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 16px;
}

.cp-bar {
  flex: 1;
  height: 8px;
  background: var(--border);
  border-radius: 4px;
  overflow: hidden;
}

.cp-fill {
  height: 100%;
  background: linear-gradient(90deg, #8A2BE2, #00FFFF);
  border-radius: 4px;
  transition: width 0.4s ease;
}

.cp-pct {
  font-size: 14px;
  font-weight: 700;
  color: var(--highlight);
  flex-shrink: 0;
  min-width: 40px;
  text-align: right;
}

/* ─── 最终视频 ─── */
.final-video-section {
  text-align: center;
}

.final-video-title {
  font-size: 16px;
  font-weight: 600;
  color: var(--highlight);
  margin-bottom: 16px;
}

.final-video-wrapper {
  width: 100%;
  max-width: 400px;
  aspect-ratio: 9 / 16;
  max-height: 520px;
  margin: 0 auto 20px;
  background: #000;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 0 40px rgba(138, 43, 226, 0.2);
}

.final-video-player {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.final-actions {
  display: flex;
  gap: 10px;
  justify-content: center;
  flex-wrap: wrap;
}

/* ─── 视频预览弹窗 ─── */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.7);
