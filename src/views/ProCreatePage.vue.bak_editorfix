      }
      this.savingShotIdx = -1
    },
    async saveShots() {
      this.savingShots = true
      try {
        // 保存分镜到项目（用 characters/save 复用保存逻辑）
        const res = await apiReq('POST', '/characters/save', {
          project_id: this.projectId,
          characters: this.characters,
          shots: this.shots.map(s => ({
            shot_num: s.shot_num || s.id,
            description: s.description || '',
            dialogue: s.dialogue || '',
            location: s.location || '',
            scene: s.scene || '',
            scene_image_url: s.scene_image_url || '',
            scene_image: s.scene_image_url || '',
            camera_movement: s.camera_movement || '',
            duration_sec: s.duration_sec || s.duration || 5,
            emotion: s.emotion || '',
            focus_character: s.focus_character || '',
          })),
        })
        if (res.success) {
          this.steps[2].done = true
        } else {
          alert('保存分镜失败: ' + (res.message || '请重试'))
        }
      } catch (e) {
        console.error('save shots failed:', e)
        alert('保存分镜失败: 网络错误')
      }
      this.savingShots = false
    },

    // ═══ Step 4: 视频生成 ═══
    // 注意：/pipeline/step 是「提交即返回 + 后台跑」，必须用轮询拿结果。
    // 后端 video 阶段会一次性生成全部镜头，前端点任一镜头的"生成"都触发整批，
    // 所以用一个 generatingVideoBatch 标志防止重复提交，结果统一回填。
    async generateVideo(sIdx) {
      if (this.generatingVideoBatch) return  // 整批已在跑，防重入
      this.generatingVideoBatch = true
      this.generatingVideoIdx = sIdx
      // 标记全部镜头为 generating
      this.shots.forEach(s => { if (!s.video_url) s.videoStatus = 'generating' })
      this.shots = [...this.shots]
      try {
        const shotsData = this.shots.map((s, i) => ({
          shot_num: i + 1,
          description: s.description,
          scene_image: s.scene_image_url || '',
          image_url: s.scene_image_url || '',
          project_id: this.projectId,
        }))
        const res = await apiReq('POST', '/pipeline/step/' + this.projectId, {
          stage: 'video',
          params: { shots: shotsData, genre: localStorage.getItem('__DRAMA_GENRE__') || '' }
        })
        if (!res.success) {
          alert('视频生成启动失败: ' + (res.error || res.message || '请重试'))
          this.shots.forEach(s => { if (s.videoStatus === 'generating') s.videoStatus = 'failed' })
          this.shots = [...this.shots]
          return
        }
        // res.data.duplicate=true 表示后端已有任务在跑，正常情况，直接轮询
        // 轮询等整批完成（video 慢，给 25 分钟）
        const vd = await this.pollStepResult('video', 1500)
        if (vd) {
          // 优先用后端顶层返回的 shot_videos（已按 shot_index 映射好）
          const shotVideos = vd.shot_videos || {}
          const shotErrors = vd.shot_video_errors || {}
          // 也解析原始 videos 数组兜底
          const rawVideos = vd.videos || vd.results || []
          const getVideoUrl = (v) => {
            if (!v) return ''
            if (typeof v === 'string') return v
            return v.video_url || v.url || (v.result && (v.result.video_url || v.result.url)) || ''
          }
          const getVideoError = (v) => {
            if (!v || typeof v === 'string') return ''
            return v.error || (v.result && v.result.error) || ''
          }
          // 先用原始数组
          if (Array.isArray(rawVideos)) {
            rawVideos.forEach(v => {
              const idx = v.shot_index ?? v.shot_num ?? v.index
              if (idx != null && idx < this.shots.length) {
                const url = getVideoUrl(v)
                if (url) {
                  this.shots[idx].video_url = url
                  this.shots[idx].videoStatus = 'completed'
                  this.shots[idx].videoError = ''
                }
              }
            })
          }
          // 再用 shot_videos 覆盖（更可靠）
          Object.keys(shotVideos).forEach(k => {
            const idx = parseInt(k)
            if (!isNaN(idx) && idx < this.shots.length && shotVideos[k]) {
              this.shots[idx].video_url = shotVideos[k]
              this.shots[idx].videoStatus = 'completed'
              this.shots[idx].videoError = ''
            }
          })
          // 标记失败的（有 error 的）
          Object.keys(shotErrors).forEach(k => {
            const idx = parseInt(k)
            if (!isNaN(idx) && idx < this.shots.length && !this.shots[idx].video_url) {
              this.shots[idx].videoStatus = 'failed'
              this.shots[idx].videoError = shotErrors[k]
            }
          })
          // 仍未拿到 url 且仍在 generating 的标记 failed
          this.shots.forEach((s, i) => {
            if (s.videoStatus === 'generating' && !s.video_url) {
              s.videoStatus = 'failed'
              s.videoError = s.videoError || '未生成'
            }
          })
        } else {
          // 轮询超时，不报错，后端仍在跑；保持 generating 让用户可刷新查看
          console.warn('视频轮询超时，后端可能仍在运行，刷新可查看')
        }
        this.shots = [...this.shots]
      } catch (e) {
        console.error('video generation failed:', e)
        this.shots.forEach(s => { if (s.videoStatus === 'generating') s.videoStatus = 'failed' })
        this.shots = [...this.shots]
      }
      this.generatingVideoIdx = null
      this.generatingVideoBatch = false
    },

    // == Step 4: 逐镜精修方法 ==
    prevShot() {
      if (this.currentShotIdx > 0) this.currentShotIdx--
    },
    nextShot() {
      if (this.currentShotIdx < this.shots.length - 1) this.currentShotIdx++
    },
    async saveShotEdit() {
      const sIdx = this.currentShotIdx
      const shot = this.shots[sIdx]
      const res = await apiReq('POST', '/pipeline/step/' + this.projectId, {
        stage: 'storyboard', action: 'update_shot',
        params: {
          shot_index: sIdx,
          description: shot.description,
          dialogue: shot.dialogue,
          shot_type: shot.shot_type,
          camera_movement: shot.camera_movement,
          camera_angle: shot.camera_angle,
          duration_sec: shot.duration_sec,
          scene: shot.scene,
          location: shot.location,
        }
      })
      if (res.success) {
        this.$forceUpdate()
      }
    },
    async generateSingleVideo() {
      console.log('[generateSingleVideo] 点击', {idx: this.currentShotIdx, generating: this.singleGenerating})
      if (this.singleGenerating) return
      const sIdx = this.currentShotIdx
      if (!this.shots[sIdx]) return
      // 没场景图自动生成
      if (!this.shots[sIdx].scene_image_url) {
        alert('该镜头暂无场景图，正在自动生成...')
        await this.batchGenerateScenes()
        if (!this.shots[sIdx].scene_image_url) { alert('场景图生成失败'); return }
      }
      this.singleGenerating = true
      this.shots[sIdx].videoStatus = 'generating'
      this.shots = [...this.shots]
      try {
        // 提交（异步，立即返回 running）
        const res = await apiReq('POST', '/pipeline/single-video/' + this.projectId, {
          shot_index: sIdx,
          shot: {
            shot_num: sIdx + 1,
            description: this.shots[sIdx].description || '',
            scene_image: this.shots[sIdx].scene_image_url || '',
            image_url: this.shots[sIdx].scene_image_url || '',
          }
        })
        console.log('[generateSingleVideo] 提交返回:', res)
        // 不管返回什么，开始轮询
        // 每10秒查一次 progress，最多等20分钟
        for (let attempt = 0; attempt < 120; attempt++) {
          await new Promise(r => setTimeout(r, 10000))
          try {
            const prog = await apiReq('GET', '/pipeline/progress/' + this.projectId)
            if (prog.success && prog.data) {
              const svs = prog.data.shot_videos || {}
              const url = svs[String(sIdx)] || svs[sIdx] || ''
              if (url) {
                this.shots[sIdx].video_url = url
                this.shots[sIdx].videoStatus = 'completed'
                this.singleGenerating = false
                this.shots = [...this.shots]
                console.log('[generateSingleVideo] 成功!', url)
                return
              }
              // 检查是否失败
              const stages = prog.data.stages || []
              const vs = stages.find(s => s.stage === 'video')
              if (vs && vs.status === 'failed' && vs.data && vs.data.generating_shot !== sIdx) {
                this.shots[sIdx].videoStatus = 'failed'
                this.shots[sIdx].videoError = '生成失败'
                this.singleGenerating = false
                this.shots = [...this.shots]
                return
              }
            }
          } catch(e) {}
        }
        // 超时
        this.shots[sIdx].videoStatus = 'failed'
        this.shots[sIdx].videoError = '超时'
      } catch(e) {
        console.error('[generateSingleVideo] error:', e)
        this.shots[sIdx].videoStatus = 'failed'
        this.shots[sIdx].videoError = '网络错误'
      }
      this.singleGenerating = false
      this.shots = [...this.shots]
    },
    async goToStep5() {
      // 缺视频自动补齐
      const missing = this.shots.filter(s => !s.video_url)
      if (missing.length > 0) {
        const ok = confirm('还有 ' + missing.length + ' 个镜头没有视频，确定要自动补齐后再合成吗？')
        if (!ok) return
        for (let i = 0; i < this.shots.length; i++) {
          if (!this.shots[i].video_url) {
            this.currentShotIdx = i
            await this.generateSingleVideo()
          }
        }
      }
      this.steps[3].done = true
      this.currentStep = 5
    },

    // ═══ 一键生成 ═══
    async autoGenerate() {
      if (!this.projectId || this.autoGenerating) return
      this.autoGenerating = true
      this.autoGenDone = false
      this.autoGenStatus = 'running'
      // 初始化阶段列表（13个阶段）
      const STAGE_DEFS = [
        { key: 'director', label: '导演分析', icon: '🎬' },
        { key: 'script', label: '剧本生成', icon: '📝' },
        { key: 'character', label: '角色建模', icon: '👤' },
        { key: 'storyboard', label: '分镜规划', icon: '📋' },
        { key: 'cinematographer', label: '摄影指导', icon: '📷' },
        { key: 'wardrobe', label: '服化道', icon: '👔' },
        { key: 'scene', label: '场景生成', icon: '🏞' },
        { key: 'sfx', label: '特效设计', icon: '✨' },
        { key: 'tts', label: '配音合成', icon: '🎙' },
        { key: 'subtitle', label: '字幕生成', icon: '💬' },
        { key: 'bgm', label: 'BGM配乐', icon: '🎵' },
        { key: 'video', label: '视频生成', icon: '🎥' },
        { key: 'composite', label: '视频合成', icon: '🎬' },
      ]
      this.autoGenStages = STAGE_DEFS.map(s => ({ ...s, status: 'pending', error: '' }))

      try {
        // 调 /pipeline/start，传 project_id，后端自动从已完成阶段续跑
        const res = await apiReq('POST', '/pipeline/start', {
          project_id: parseInt(this.projectId),
          script_text: this.scriptText || '',
          genre: localStorage.getItem('__DRAMA_GENRE__') || '',
          title: this.scriptText ? this.scriptText.slice(0, 20) : '短剧',
        })
        if (!res.success && !res.pipeline_id) {
          alert('一键生成启动失败: ' + (res.message || res.error || '请重试'))
          this.autoGenerating = false
          return
        }
        // 轮询进度
        this._pollAutoGen()
      } catch (e) {
        console.error('auto generate failed:', e)
        alert('一键生成失败: ' + (e.message || '网络错误'))
        this.autoGenerating = false
      }
    },

    _pollAutoGen() {
      if (this.autoGenPollTimer) clearInterval(this.autoGenPollTimer)
      this.autoGenPollTimer = setInterval(async () => {
        try {
          const res = await apiReq('GET', '/pipeline/progress/' + this.projectId)
          if (!res.success || !res.data) return
          const stages = res.data.stages || []
          // 更新阶段状态
          stages.forEach(st => {
            const found = this.autoGenStages.find(a => a.key === st.stage)
            if (found) {
              found.status = st.status === 'paused' ? 'failed' : st.status
              found.error = st.error || ''
            }
          })
          // 检查最终视频
          if (res.data.final_video_url) {
            this.finalVideoUrl = res.data.final_video_url
          }
          // 检查是否全部结束
          const hasRunning = stages.some(s => s.status === 'running' || s.status === 'pending')
          const hasFailed = stages.some(s => s.status === 'failed' || s.status === 'paused')
          const allDone = stages.length >= 13 && stages.every(s => s.status === 'completed')
          if (allDone) {
            this._finishAutoGen('completed')
          } else if (!hasRunning && hasFailed) {
            // 全部跑完但有失败
            this._finishAutoGen('failed')
          }
        } catch (e) {}
      }, 5000)
    },

    _finishAutoGen(status) {
      if (this.autoGenPollTimer) {
        clearInterval(this.autoGenPollTimer)
        this.autoGenPollTimer = null
      }
      this.autoGenerating = false
      this.autoGenDone = true
      this.autoGenStatus = status
    },

    // ═══ Step 5: 合成发布 ═══
    async startComposite() {
      this.isCompositing = true
      this.compositeProgress = 0
      try {
        // 对接正式管道 /pipeline/step，stage=composite
        const clips = this.shots.filter(s => s.video_url).map(s => ({
          video: s.video_url,
          description: s.description,
          duration_sec: parseInt(s.duration) || 5,
        }))
        const res = await apiReq('POST', '/pipeline/step/' + this.projectId, {
          stage: 'composite',
          params: { clips: clips }
        })
        if (res.success && res.data) {
          const taskId = res.data.task_id || res.data.composite_id
          this.startCompositePolling(taskId)
        } else {
          alert('合成启动失败: ' + (res.message || '请重试'))
          this.isCompositing = false
        }
      } catch (e) {
        console.error('composite start failed:', e)
        alert('合成启动失败: 网络错误')
        this.isCompositing = false
      }
    },

    startCompositePolling(taskId) {
      this.stopCompositePolling()
      this.compositePollTimer = setInterval(async () => {
        try {
          const res = await apiReq('GET', '/video/composite/progress/' + taskId)
          if (res.success && res.data) {
            this.compositeProgress = res.data.progress || res.data.percent || 0
            if (res.data.finished || res.data.status === 'completed') {
              this.finalVideoUrl = res.data.video_url || res.data.url || ''
              this.isCompositing = false
              this.stopCompositePolling()
            }
            if (res.data.status === 'failed') {
              alert('合成失败: ' + (res.data.error || '请重试'))
              this.isCompositing = false
              this.stopCompositePolling()
            }
          }
          if (this.compositeProgress >= 100) {
            // 保险：刷新一次获取最终 url
            const r2 = await apiReq('GET', '/video/composite/progress/' + taskId)
            if (r2.success && r2.data && r2.data.video_url) {
              this.finalVideoUrl = r2.data.video_url
            }
            this.isCompositing = false
            this.stopCompositePolling()
          }
        } catch (e) {
          console.warn('composite poll failed:', e)
        }
      }, 2000)
    },

    stopCompositePolling() {
      if (this.compositePollTimer) {
        clearInterval(this.compositePollTimer)
        this.compositePollTimer = null
      }
    },

    downloadFinalVideo() {
      if (this.finalVideoUrl) {
        const a = document.createElement('a')
        a.href = this.finalVideoUrl
        a.download = ''
        document.body.appendChild(a)
        a.click()
        document.body.removeChild(a)
      }
    },

    shareFinalVideo() {
      if (navigator.share && this.finalVideoUrl) {
        navigator.share({ title: '智剧AI - 短剧作品', url: this.finalVideoUrl }).catch(() => {})
      } else if (navigator.clipboard) {
        navigator.clipboard.writeText(this.finalVideoUrl || window.location.href)
          .then(() => alert('链接已复制到剪贴板'))
          .catch(() => {
            const input = document.createElement('input')
            input.value = this.finalVideoUrl
            document.body.appendChild(input)
            input.select()
            document.execCommand('copy')
            document.body.removeChild(input)
            alert('链接已复制到剪贴板')
          })
      }
    },

    resetAll() {
      this.stopCompositePolling()
      this.finalVideoUrl = ''
      this.compositeProgress = 0
      this.currentStep = 4
      this.steps[3].done = false
      this.steps[4].done = false
    },

    previewVideo(url) {
      if (url) this.videoPreviewUrl = url
    },

    previewImage(url) {
      if (url) this.previewImgUrl = url
    },

    // 恢复项目
    async loadProject(id) {
      try {
        const res = await apiReq('GET', '/projects/' + id)
        const data = res.project || res.data || {}
        if (res.success && data && data.id) {
          if (data.script) this.scriptText = data.script
          if (data.characters) {
            try {
              const chars = typeof data.characters === 'string' ? JSON.parse(data.characters) : data.characters
              if (Array.isArray(chars)) this.characters = chars
            } catch(e) {}
          }
          // 从 pipeline progress 加载分镜和场景图
          try {
            const prog = await apiReq('GET', '/pipeline/progress/' + id)
            if (prog.success && prog.data) {
              const stages = prog.data.stages || []
              const sb = stages.find(s => s.stage === 'storyboard')
              if (sb && sb.status === 'completed' && sb.data && sb.data.shots) {
                this.shots = sb.data.shots.map(s => ({
                  id: s.id || s.shot_id || s.shot_num || '',
                  description: s.description || s.content || '',
                  dialogue: s.dialogue || '',
                  scene: s.scene || '',
                  location: s.location || '',
                  shot_type: s.shot_type || '',
                  camera: s.camera || s.camera_movement || '中景',
                  duration: (s.duration_sec || s.duration || 5) + 's',
                  scene_image_url: s.scene_image_url || s.image_url || '',
            director_shot: s.director_shot || '',
            sound_design: s.sound_design || '',
            duration_sec: s.duration_sec || 8,
            camera_angle: s.camera_angle || '',
            lighting: s.lighting || '',
                  video_url: s.video_url || '',
                  videoStatus: s.videoStatus || 'pending',
                }))
              }
              const sc = stages.find(s => s.stage === 'scene')
              if (sc && sc.status === 'completed' && sc.data && sc.data.image_map) {
                const im = sc.data.image_map
                this.shots = this.shots.map((s, i) => {
                  const img = im[String(i)] || im[i] || ''
                  return img ? { ...s, scene_image_url: img } : s
                })
              }
              // 加载已生成的视频（后端顶层 shot_videos 按 shot_index 映射）
              const svs = prog.data.shot_videos || {}
              const sve = prog.data.shot_video_errors || {}
              if (Object.keys(svs).length || Object.keys(sve).length) {
                this.shots = this.shots.map((s, i) => {
                  const url = svs[String(i)] || svs[i] || ''
                  const err = sve[String(i)] || sve[i] || ''
                  if (url) return { ...s, video_url: url, videoStatus: 'completed', videoError: '' }
                  if (err) return { ...s, videoStatus: 'failed', videoError: err }
                  return s
                })
              }
              // 合成视频
              if (prog.data.final_video_url) {
                this.finalVideoUrl = prog.data.final_video_url
              }
            }
          } catch(e) { console.warn('load progress failed:', e) }
          // 跳到对应步骤
          this.steps[0].done = true
          this.currentStep = 2
          if (this.characters.length) {
            this.steps[1].done = true
            this.currentStep = 3
          }
          if (this.shots.length) {
            this.steps[2].done = true
            this.currentStep = 4
          }
        }
      } catch (e) {
        console.warn('load project failed:', e)
      }
    },

    // ─── 上传头像 ───
    triggerUpload(idx) {
      const refName = 'fileInput' + idx
      const els = this.$refs[refName]
      if (els) {
        const input = Array.isArray(els) ? els[0] : els
        if (input) input.click()
      }
    },

    async handleUpload(e, idx) {
      const file = e.target.files && e.target.files[0]
      if (!file) return
      const fd = new FormData()
      fd.append('file', file)
      fd.append('media_type', 'figures')
      try {
        const token = this.token || localStorage.getItem('token') || ''
        const res = await fetch('/api/v1/media/library/upload', {
          method: 'POST',
          headers: token ? { 'Authorization': 'Bearer ' + token } : {},
          body: fd,
        })
        const json = await res.json()
        if (json.success && json.data && json.data.url) {
          this.characters[idx].ref_image = json.data.url
          // 清除旧肖像，让页面显示新上传的图
          this.characters[idx].portrait_url = ''
          // 触发响应式更新
          this.characters = [...this.characters]
          // 自动保存到DB，确保生成形象时能拿到ref_image
          this.saveCharacters()
        } else {
          alert('上传失败: ' + (json.message || '请重试'))
        }
      } catch (e) {
        console.error('upload failed:', e)
        alert('上传失败: 网络错误')
      }
      // 重置 file input，允许重复上传同一文件
      e.target.value = ''
    },
  },
}
</script>

