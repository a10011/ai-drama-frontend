  background: linear-gradient(135deg, #1a1028 0%, #1e1038 50%, #0f1a2e 100%);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 36px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.balance-hero::before {
  content: '';
