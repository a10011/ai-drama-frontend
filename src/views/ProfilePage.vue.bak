<template>
  <div class="profile-page">
    <!-- 余额大卡片 -->
    <div class="balance-hero">
      <div class="balance-amount">💰 {{ balance.toFixed(2) }}</div>
      <div class="balance-meta">
        <span>累计充值 ¥{{ totalCharged.toFixed(2) }}</span>
        <span class="meta-divider">|</span>
        <span>消费 ¥{{ totalSpent.toFixed(2) }}</span>
      </div>
      <button class="recharge-btn-main" @click="showRecharge = true">🔋 充值</button>
    </div>

    <!-- 费用统计 -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-icon">📅</div>
        <div class="stat-info">
          <div class="stat-value">¥{{ stats.month_amount.toFixed(2) }}</div>
          <div class="stat-label">本月消费</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-info">
          <div class="stat-value">¥{{ stats.week_amount.toFixed(2) }}</div>
          <div class="stat-label">本周消费</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">📦</div>
        <div class="stat-info">
          <div class="stat-value">{{ stats.total_count }}</div>
          <div class="stat-label">累计订单</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">✅</div>
        <div class="stat-info">
          <div class="stat-value">{{ stats.completed_count }}</div>
          <div class="stat-label">已完成</div>
        </div>
      </div>
    </div>

    <!-- 最近订单 -->
    <div class="section-card">
      <div class="section-header">
        <h3>📋 最近订单</h3>
        <router-link to="/history" class="view-all">查看全部 →</router-link>
      </div>
      <div v-if="loading" class="loading-text">加载中...</div>
      <div v-else-if="recentOrders.length === 0" class="empty-text">暂无订单</div>
      <div v-else class="order-list">
        <div v-for="order in recentOrders" :key="order.id" class="order-item">
          <div class="order-left">
            <div class="order-id">{{ order.order_no || 'ORD-' + order.id }}</div>
            <div class="order-name">{{ order.name || order.script_name || '短剧订单' }}</div>
          </div>
          <div class="order-right">
            <div class="order-amount">¥{{ (order.amount || 0).toFixed(2) }}</div>
            <div class="order-status" :class="order.status">{{ order.status || 'pending' }}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- 账号设置 -->
    <div class="section-card">
      <div class="section-header">
        <h3>⚙️ 账号设置</h3>
      </div>
      <div class="account-info">
        <div class="info-row">
          <span class="info-label">用户名</span>
          <span class="info-value">{{ username || '—' }}</span>
        </div>
        <div class="info-row">
          <span class="info-label">会员等级</span>
          <span class="info-value tier-badge" :class="tierClass">{{ userTier || 'free' }}</span>
        </div>
        <div class="info-row">
          <span class="info-label">用户ID</span>
          <span class="info-value">{{ userId || '—' }}</span>
        </div>
      </div>
      <div class="logout-wrap">
        <button class="btn-logout" @click="logout">退出登录</button>
      </div>
    </div>

    <!-- 充值弹窗 -->
    <div class="modal-overlay" v-if="showRecharge" @click.self="showRecharge = false">
      <div class="recharge-modal">
        <h3>🔋 充值算力</h3>
        <p class="modal-sub">选择充值金额</p>
        <div class="amount-grid">
          <button
            v-for="amt in rechargeAmounts"
            :key="amt"
            class="amount-btn"
            :class="{ active: rechargeAmount === amt }"
            @click="rechargeAmount = amt"
          >
            ¥{{ amt }}
          </button>
        </div>
        <div class="custom-amount">
          <input v-model.number="customAmount" type="number" placeholder="自定义金额" min="1" />
        </div>
        <div class="modal-actions">
          <button class="btn-cancel" @click="showRecharge = false">取消</button>
          <button class="btn-confirm" @click="doRecharge" :disabled="recharging">
            {{ recharging ? '充值中...' : '确认充值 ¥' + finalAmount }}
          </button>
        </div>
        <div v-if="rechargeMsg" class="recharge-msg" :class="{ error: rechargeError }">
          {{ rechargeMsg }}
        </div>
      </div>
    </div>
  </div>
</template>

<script>
export default {
  name: 'ProfilePage',
  data() {
    return {
      balance: 0,
      totalCharged: 0,
      totalSpent: 0,
      username: '',
      userTier: '',
      userId: '',
      token: '',
      loading: true,
      recentOrders: [],
      stats: {
        total_amount: 0,
        total_count: 0,
        month_amount: 0,
        week_amount: 0,
        completed_count: 0,
      },
      // Recharge modal
      showRecharge: false,
      rechargeAmount: 10,
      rechargeAmounts: [10, 20, 50, 100],
      customAmount: null,
      recharging: false,
      rechargeMsg: '',
      rechargeError: false,
    }
  },
  computed: {
    tierClass() {
      const t = (this.userTier || '').toLowerCase()
      if (t === 'pro' || t === 'vip') return 'tier-pro'
      if (t === 'premium') return 'tier-premium'
      return 'tier-free'
    },
    finalAmount() {
      return this.customAmount || this.rechargeAmount
    },
  },
  methods: {
    authHeaders() {
      return { 'Authorization': 'Bearer ' + (this.token || localStorage.getItem('token') || '') }
    },
    async fetchAll() {
      this.token = localStorage.getItem('token') || ''
      if (!this.token) {
        this.loading = false
        return
      }
      const h = this.authHeaders()
      try {
        const [bal, me, orders, stats] = await Promise.all([
          fetch('/api/v1/billing/balance', { headers: h }).then(r => r.json()),
          fetch('/api/v1/auth/me', { headers: h }).then(r => r.json()),
          fetch('/api/v1/orders/my', { headers: h }).then(r => r.json()),
          fetch('/api/v1/orders/stats/summary', { headers: h }).then(r => r.json()),
        ])

        if (bal.success) {
          this.balance = bal.data.balance || 0
          this.totalCharged = bal.data.total_charged || 0
          this.totalSpent = bal.data.total_spent || 0
        }
        if (me.success) {
          this.username = me.data.username || ''
          this.userTier = me.data.tier || ''
          this.userId = me.data.id || ''
        }
        if (orders.success) {
          this.recentOrders = (orders.data || []).slice(0, 5)
        }
        if (stats.success) {
          this.stats = stats.data || this.stats
        }
      } catch (e) {
        // silent
      } finally {
        this.loading = false
      }
    },
    async doRecharge() {
      const amount = this.finalAmount
      if (!amount || amount <= 0) {
        this.rechargeMsg = '请输入有效金额'
        this.rechargeError = true
        return
      }
      this.recharging = true
      this.rechargeMsg = ''
      this.rechargeError = false
      try {
        const r = await fetch('/api/v1/billing/recharge', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            ...this.authHeaders(),
          },
          body: JSON.stringify({ amount }),
        }).then(r => r.json())
        if (r.success) {
          this.balance = r.data.balance || this.balance
          this.rechargeMsg = '充值成功！余额已更新'
          this.rechargeError = false
          setTimeout(() => {
            this.showRecharge = false
            this.rechargeMsg = ''
            // Refresh all data
            this.fetchAll()
          }, 1500)
        } else {
          this.rechargeMsg = r.detail || r.message || '充值失败'
          this.rechargeError = true
        }
      } catch (e) {
        this.rechargeMsg = '网络错误，请重试'
        this.rechargeError = true
      } finally {
        this.recharging = false
      }
    },
    logout() {
      localStorage.removeItem('token')
      localStorage.removeItem('username')
      this.$router.push('/login')
    },
  },
  mounted() {
    this.fetchAll()
  },
}
</script>

<style scoped>
/* ===== 赛博紫+霓虹青配色 ===== */
