<template>
<div class="profile-page">
  <div class="profile-card">
    <div class="pf-avatar" :class="tierClass">{{ avatarLetter }}</div>
    <div class="pf-info">
      <div class="pf-name-row">
        <h2>{{ userInfo.username || '创作用户' }}</h2>
        <span class="tier-badge" :class="tierClass">{{ tierLabel }}</span>
      </div>
      <p>{{ userInfo.email || '' }}</p>
      <p class="pf-meta">用户ID: {{ userInfo.user_id }} · 注册于 {{ formatDate(userInfo.created) }}</p>
    </div>
  </div>

  <div class="pf-menu">
    <div class="menu-item" @click="$router.push('/projects')">
      <span class="mi-icon">🎞️</span><span class="mi-label">我的作品</span><span class="mi-arrow">→</span>
    </div>
    <div class="menu-item" @click="$router.push('/media')">
      <span class="mi-icon">🎭</span><span class="mi-label">素材库</span><span class="mi-arrow">→</span>
    </div>
    <div class="menu-item" @click="$router.push('/tasks')">
      <span class="mi-icon">⚙️</span><span class="mi-label">任务记录</span><span class="mi-arrow">→</span>
    </div>
    <div class="menu-item" @click="$router.push('/keys')">
      <span class="mi-icon">🔑</span><span class="mi-label">API Key 管理</span><span class="mi-arrow">→</span>
    </div>
  </div>

  <div class="pf-divider"></div>

  <div class="pf-menu">
    <div class="menu-item" @click="contactService">
      <span class="mi-icon">💬</span><span class="mi-label">联系客服</span><span class="mi-arrow">→</span>
    </div>
    <div class="menu-item danger" @click="logout">
      <span class="mi-icon">🚪</span><span class="mi-label">退出登录</span><span class="mi-arrow">→</span>
    </div>
  </div>
</div>
</template>

<script setup>
import {ref,onMounted,computed} from 'vue'
import {useRouter} from 'vue-router'
import request from '@/utils/request'
const router=useRouter()
const userInfo=ref({user_id:'',username:'',email:'',tier:'free',created:null})

const avatarLetter=computed(()=>userInfo.value.username?(userInfo.value.username[0].toUpperCase()):'?')
const tierClass=computed(()=>'tier-'+userInfo.value.tier)
const tierLabel=computed(()=>{
  const m={free:'免费用户',vip:'VIP会员',pro:'Pro专业版'}
  return m[userInfo.value.tier]||'免费用户'
})

onMounted(async()=>{
  try{
    const token=localStorage.getItem('token')
    if(!token)return
    const data = await request({ url: '/api/v1/auth/me', params: { token } })
    if(data?.success&&data?.data)userInfo.value=data.data
    else if(data?.username)userInfo.value=data
  }catch(e) { console.error("[ProfilePage] 操作失败:", e) }
  })
  function formatDate(ts){
  if(!ts)return ''
  const d=new Date(ts*1000)
  return d.toLocaleDateString('zh-CN')
}

function contactService(){
  window.open('https://ai.mzsh.top/api/memory/cs/chat','_blank')
}

function logout(){
  localStorage.removeItem('token')
  router.push('/login')
}
</script>

<style scoped>
.profile-page{padding:24px 32px;color:var(--text-primary);font-family:'Inter','Noto Sans SC',-apple-system,sans-serif;max-width:600px}
.profile-card{display:flex;align-items:center;gap:20px;padding:24px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:24px}
.pf-avatar{width:64px;height:64px;border-radius:50%;color:#fff;font-family:'Inter','Noto Sans SC',-apple-system,sans-serif;font-weight:bold;font-size:28px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.pf-avatar.tier-free{background:linear-gradient(135deg,var(--text-muted),var(--border))}
.pf-avatar.tier-vip{background:linear-gradient(135deg,var(--accent),var(--highlight))}
.pf-avatar.tier-pro{background:linear-gradient(135deg,var(--accent),#FFD740)}
.pf-info{flex:1}
.pf-name-row{display:flex;align-items:center;gap:10px;margin-bottom:4px}
.pf-name-row h2{font-size:18px;color:var(--text-primary);margin:0}
.tier-badge{font-size:10px;padding:2px 10px;border-radius:10px;font-weight:bold}
.tier-badge.tier-free{background:var(--border);color:var(--text-secondary)}
.tier-badge.tier-vip{background:var(--accent-glow);color:var(--highlight);border:1px solid var(--accent-glow)}
.tier-badge.tier-pro{background:linear-gradient(135deg,var(--accent-glow),rgba(255,215,64,.1));color:#FFD740;border:1px solid rgba(255,215,64,.3)}
.pf-info p{font-size:13px;color:var(--text-secondary);margin:2px 0}
.pf-meta{color:var(--text-muted)!important;font-size:11px!important}
.pf-menu{display:flex;flex-direction:column;gap:2px}
.menu-item{display:flex;align-items:center;gap:12px;padding:14px 16px;background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;transition:.2s;margin-bottom:4px}
.menu-item:hover{border-color:var(--highlight);background:var(--accent-glow)}
.mi-icon{font-size:18px;width:28px;text-align:center}
.mi-label{flex:1;font-size:14px;color:var(--text-primary)}
.mi-arrow{font-size:14px;color:var(--text-muted)}
.menu-item.danger .mi-label{color:var(--danger)}
.menu-item.danger:hover{border-color:var(--danger);background:rgba(255,82,82,.06)}
.pf-divider{height:1px;background:var(--border);margin:16px 0}
@media(max-width:768px){.profile-page{padding:16px}}
</style>